@using X.PagedList.Mvc.Core
@using X.PagedList
@model IPagedList<Blog>
@{
    ViewData["Title"] = "Blog & Tin tức";
}

@section Styles {
<style>
    .blog-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;overflow:hidden;transition:transform .2s,box-shadow .2s;display:flex;flex-direction:column;height:100%}
    .blog-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px rgba(15,23,42,.08)}
    .blog-card img{width:100%;height:200px;object-fit:cover}
    .blog-card .blog-body{padding:16px;display:flex;flex-direction:column;flex:1}
    .blog-title{font-weight:600;font-size:15px;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:45px}
    .blog-excerpt{color:var(--muted);font-size:13px;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .blog-featured{background:#fff;border:1px solid #e5e7eb;border-radius:20px;overflow:hidden;margin-bottom:32px}
    .blog-featured img{width:100%;height:320px;object-fit:cover}
    .page-header{background:#fff;padding:32px 0;border-bottom:1px solid #e5e7eb;margin-bottom:2rem}
</style>
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Blog</li>
            </ol>
        </nav>
        <h2 class="fw-bold mb-0">Blog & Tin tức</h2>
    </div>
</div>

<div class="container my-4">
    @if (Model.Any())
    {
        var featured = Model.FirstOrDefault();
        if (featured != null)
        {
            <div class="blog-featured">
                <div class="row g-0">
                    <div class="col-lg-6">
                        @if (!string.IsNullOrEmpty(featured.ThumbnailUrl))
                        {
                            <img src="@featured.ThumbnailUrl" alt="@featured.Title" style="height:100%;min-height:280px;object-fit:cover;width:100%">
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80" 
                                 alt="@featured.Title" style="height:100%;min-height:280px;object-fit:cover;width:100%">
                        }
                    </div>
                    <div class="col-lg-6 p-4 d-flex flex-column justify-content-center">
                        <span class="badge bg-primary mb-2" style="width:fit-content">Nổi bật</span>
                        <h3 class="fw-bold mb-3">@featured.Title</h3>
                        @if (!string.IsNullOrEmpty(featured.Summary))
                        {
                            <p class="text-muted">@featured.Summary</p>
                        }
                        <div class="text-muted small mb-3">
                            <i class="bi bi-calendar3 me-1"></i> @featured.Created.ToString("dd/MM/yyyy")
                        </div>
                        <a asp-action="Detail" asp-route-id="@featured.Id" class="btn btn-brand" style="width:fit-content">
                            Đọc thêm <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }

        <div class="row g-4">
            @foreach (var blog in Model.Skip(1))
            {
                <div class="col-md-4">
                    <a asp-action="Detail" asp-route-id="@blog.Id" style="text-decoration:none;color:inherit">
                        <div class="blog-card">
                            @if (!string.IsNullOrEmpty(blog.ThumbnailUrl))
                            {
                                <img src="@blog.ThumbnailUrl" alt="@blog.Title">
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=900&q=80" 
                                     alt="@blog.Title">
                            }
                            <div class="blog-body">
                                <h6 class="blog-title">@blog.Title</h6>
                                @if (!string.IsNullOrEmpty(blog.Summary))
                                {
                                    <p class="blog-excerpt">@blog.Summary</p>
                                }
                                <div class="text-muted small mt-auto">
                                    <i class="bi bi-calendar3 me-1"></i> @blog.Created.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (Model.PageCount > 1)
        {
            <nav class="mt-4">
                @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
                {
                    LiElementClasses = new[] { "page-item" },
                    PageClasses = new[] { "page-link" },
                    UlElementClasses = new[] { "pagination", "justify-content-center" }
                })
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Chưa có bài viết nào
        </div>
    }
</div>
