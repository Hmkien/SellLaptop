@model Order
@using WebsiteSellLaptop.Models.Enums

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var user = ViewBag.User as AppUser;
}

@section Styles {
<style>
    .sidebar{background:#fff;border-radius:16px;border:1px solid #e5e7eb;overflow:hidden}
    .sidebar .user-info{padding:24px;border-bottom:1px solid #e5e7eb;display:flex;align-items:center;gap:14px}
    .sidebar .avatar{width:56px;height:56px;border-radius:50%;background:#eef2ff;display:flex;align-items:center;justify-content:center;font-size:28px;color:var(--brand)}
    .sidebar .nav-pills .nav-link{color:var(--dark);padding:12px 24px;border-radius:0;font-weight:500;display:flex;align-items:center;gap:10px;border-left:3px solid transparent}
    .sidebar .nav-pills .nav-link:hover{background:#f8fafc}
    .sidebar .nav-pills .nav-link.active{background:#eef2ff;color:var(--brand);border-left-color:var(--brand);font-weight:600}
    .sidebar .nav-pills .nav-link i{width:20px;text-align:center}
    .content-card{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:28px}
    .content-card h5{font-weight:700;margin-bottom:20px}
    .info-box{background:#f8fafc;border-radius:12px;padding:20px;margin-bottom:16px}
    .badge-status{padding:6px 14px;border-radius:50rem;font-size:13px;font-weight:600}
    .status-pending{background:#fef3c7;color:#d97706}
    .status-confirmed{background:#dbeafe;color:#2563eb}
    .status-shipping{background:#e0e7ff;color:#6366f1}
    .status-completed{background:#dcfce7;color:#16a34a}
    .status-cancelled{background:#fee2e2;color:#dc2626}
    .product-item{display:flex;gap:16px;padding:16px;border-bottom:1px solid #f1f3f7}
    .product-item:last-child{border-bottom:0}
    .product-item img{width:80px;height:80px;border-radius:10px;object-fit:cover;border:1px solid #e5e7eb}
</style>
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Account" asp-action="Orders">Đơn hàng</a></li>
            <li class="breadcrumb-item active">Chi tiết #@Model.OrderCode</li>
        </ol>
    </nav>
</div>

<main class="container mb-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="sidebar">
                <div class="user-info">
                    <div class="avatar"><i class="bi bi-person-fill"></i></div>
                    <div>
                        <div class="fw-bold">@user?.FullName</div>
                        <div class="text-muted small">@user?.Email</div>
                    </div>
                </div>
                <nav class="nav nav-pills flex-column">
                    <a asp-action="Profile" class="nav-link"><i class="bi bi-person"></i> Thông tin cá nhân</a>
                    <a asp-action="Orders" class="nav-link active"><i class="bi bi-box-seam"></i> Đơn hàng</a>
                    <form asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-link text-danger border-0 bg-transparent text-start w-100">
                            <i class="bi bi-box-arrow-left"></i> Đăng xuất
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <!-- Content -->
        <div class="col-lg-9">
            <div class="content-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h5 class="mb-1">Đơn hàng #@Model.OrderCode</h5>
                        <div class="text-muted small">Đặt ngày: @Model.Created.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    @switch (Model.OrderStatus)
                    {
                        case OrderStatus.Pending: <span class="badge-status status-pending"><i class="bi bi-clock me-1"></i>Chờ xác nhận</span> break;
                        case OrderStatus.Confirmed: <span class="badge-status status-confirmed"><i class="bi bi-check-circle me-1"></i>Đã xác nhận</span> break;
                        case OrderStatus.Shipping: <span class="badge-status status-shipping"><i class="bi bi-truck me-1"></i>Đang giao</span> break;
                        case OrderStatus.Completed: <span class="badge-status status-completed"><i class="bi bi-check-all me-1"></i>Hoàn thành</span> break;
                        case OrderStatus.Cancelled: <span class="badge-status status-cancelled"><i class="bi bi-x-circle me-1"></i>Đã hủy</span> break;
                    }
                </div>

                <!-- Order Timeline -->
                <div class="mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-center" style="width:50px">
                            <div style="width:40px;height:40px;border-radius:50%;background:@(Model.OrderStatus >= OrderStatus.Pending ? "#dcfce7" : "#f3f4f6");display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-check" style="color:@(Model.OrderStatus >= OrderStatus.Pending ? "#16a34a" : "#9ca3af")"></i>
                            </div>
                            <div class="small mt-1">Đặt hàng</div>
                        </div>
                        <div style="flex:1;height:2px;background:#e5e7eb"></div>
                        <div class="text-center" style="width:50px">
                            <div style="width:40px;height:40px;border-radius:50%;background:@(Model.OrderStatus >= OrderStatus.Confirmed ? "#dcfce7" : "#f3f4f6");display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-check-circle" style="color:@(Model.OrderStatus >= OrderStatus.Confirmed ? "#16a34a" : "#9ca3af")"></i>
                            </div>
                            <div class="small mt-1">Xác nhận</div>
                        </div>
                        <div style="flex:1;height:2px;background:#e5e7eb"></div>
                        <div class="text-center" style="width:50px">
                            <div style="width:40px;height:40px;border-radius:50%;background:@(Model.OrderStatus >= OrderStatus.Shipping ? "#dcfce7" : "#f3f4f6");display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-truck" style="color:@(Model.OrderStatus >= OrderStatus.Shipping ? "#16a34a" : "#9ca3af")"></i>
                            </div>
                            <div class="small mt-1">Đang giao</div>
                        </div>
                        <div style="flex:1;height:2px;background:#e5e7eb"></div>
                        <div class="text-center" style="width:50px">
                            <div style="width:40px;height:40px;border-radius:50%;background:@(Model.OrderStatus == OrderStatus.Completed ? "#dcfce7" : "#f3f4f6");display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-check-all" style="color:@(Model.OrderStatus == OrderStatus.Completed ? "#16a34a" : "#9ca3af")"></i>
                            </div>
                            <div class="small mt-1">Hoàn thành</div>
                        </div>
                    </div>
                </div>

                <!-- Customer Info -->
                <div class="info-box">
                    <h6 class="fw-bold mb-3"><i class="bi bi-person me-2"></i>Thông tin người nhận</h6>
                    <div class="row">
                        <div class="col-md-6 mb-2"><strong>Họ tên:</strong> @Model.FullName</div>
                        <div class="col-md-6 mb-2"><strong>SĐT:</strong> @Model.Phone</div>
                        <div class="col-md-6 mb-2"><strong>Email:</strong> @Model.Email</div>
                        <div class="col-md-6 mb-2">
                            <strong>Thanh toán:</strong> 
                            @switch (Model.PaymentMethod)
                            {
                                case PaymentMethod.COD: <span>COD</span> break;
                                case PaymentMethod.BankTransfer: <span>Chuyển khoản</span> break;
                                case PaymentMethod.CreditCard: <span>Thẻ tín dụng</span> break;
                                case PaymentMethod.EWallet: <span>VNPay</span> break;
                            }
                        </div>
                        <div class="col-12"><strong>Địa chỉ:</strong> @Model.Address</div>
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="col-12 mt-2"><strong>Ghi chú:</strong> @Model.Note</div>
                        }
                    </div>
                </div>

                <!-- Products -->
                <h6 class="fw-bold mb-3"><i class="bi bi-box-seam me-2"></i>Sản phẩm</h6>
                <div style="border:1px solid #e5e7eb;border-radius:12px;overflow:hidden">
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        @foreach (var detail in Model.OrderDetails)
                        {
                            <div class="product-item">
                                @if (!string.IsNullOrEmpty(detail.Product?.ThumbnailUrl))
                                {
                                    <img src="@detail.Product.ThumbnailUrl" alt="@detail.Product.Name">
                                }
                                else
                                {
                                    <div style="width:80px;height:80px;border-radius:10px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;border:1px solid #e5e7eb">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <div class="fw-semibold mb-1">@detail.Product?.Name</div>
                                    <div class="text-muted small mb-2">Số lượng: x@detail.Quantity</div>
                                    <div class="fw-semibold text-primary">@detail.UnitPrice.ToString("N0")₫</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-primary" style="font-size:18px">@detail.TotalPrice.ToString("N0")₫</div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Summary -->
                <div class="info-box mt-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính:</span>
                        <span class="fw-semibold">@Model.TotalAmount.ToString("N0")₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="fw-semibold text-success">Miễn phí</span>
                    </div>
                    @if (Model.DiscountAmount.HasValue && Model.DiscountAmount > 0)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Giảm giá @(!string.IsNullOrEmpty(Model.CouponCode) ? $"({Model.CouponCode})" : ""):</span>
                            <span class="fw-semibold text-danger">-@Model.DiscountAmount.Value.ToString("N0")₫</span>
                        </div>
                    }
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold" style="font-size:18px">Tổng cộng:</span>
                        <span class="fw-bold text-primary" style="font-size:20px">@((Model.TotalAmount - (Model.DiscountAmount ?? 0)).ToString("N0"))₫</span>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="Orders" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại đơn hàng
                    </a>
                    @if (Model.OrderStatus == OrderStatus.Completed)
                    {
                        <a asp-controller="Product" asp-action="Index" class="btn btn-brand">
                            <i class="bi bi-bag-plus me-1"></i>Mua thêm
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</main>
