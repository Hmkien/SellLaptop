@model List<Order>
@using WebsiteSellLaptop.Models.Enums

@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var user = ViewBag.User as AppUser;
    var statusFilter = ViewBag.StatusFilter as OrderStatus?;
}

@section Styles {
<style>
    .sidebar{background:#fff;border-radius:16px;border:1px solid #e5e7eb;overflow:hidden}
    .sidebar .user-info{padding:24px;border-bottom:1px solid #e5e7eb;display:flex;align-items:center;gap:14px}
    .sidebar .avatar{width:56px;height:56px;border-radius:50%;background:#eef2ff;display:flex;align-items:center;justify-content:center;font-size:28px;color:var(--brand)}
    .sidebar .nav-pills .nav-link{color:var(--dark);padding:12px 24px;border-radius:0;font-weight:500;display:flex;align-items:center;gap:10px;border-left:3px solid transparent}
    .sidebar .nav-pills .nav-link:hover{background:#f8fafc}
    .sidebar .nav-pills .nav-link.active{background:#eef2ff;color:var(--brand);border-left-color:var(--brand);font-weight:600}
    .sidebar .nav-pills .nav-link i{width:20px;text-align:center}
    .content-card{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:28px}
    .content-card h5{font-weight:700;margin-bottom:20px}
    .order-card{background:#f8fafc;border:1px solid #e5e7eb;border-radius:14px;padding:20px;margin-bottom:16px}
    .order-card:hover{box-shadow:0 2px 8px rgba(0,0,0,.08)}
    .badge-status{padding:4px 12px;border-radius:50rem;font-size:12px;font-weight:600}
    .status-pending{background:#fef3c7;color:#d97706}
    .status-confirmed{background:#dbeafe;color:#2563eb}
    .status-shipping{background:#e0e7ff;color:#6366f1}
    .status-completed{background:#dcfce7;color:#16a34a}
    .status-cancelled{background:#fee2e2;color:#dc2626}
</style>
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Đơn hàng</li>
        </ol>
    </nav>
</div>

<main class="container mb-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="sidebar">
                <div class="user-info">
                    <div class="avatar"><i class="bi bi-person-fill"></i></div>
                    <div>
                        <div class="fw-bold">@user?.FullName</div>
                        <div class="text-muted small">@user?.Email</div>
                    </div>
                </div>
                <nav class="nav nav-pills flex-column">
                    <a asp-action="Profile" class="nav-link"><i class="bi bi-person"></i> Thông tin cá nhân</a>
                    <a asp-action="Orders" class="nav-link active"><i class="bi bi-box-seam"></i> Đơn hàng</a>
                    <form asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-link text-danger border-0 bg-transparent text-start w-100">
                            <i class="bi bi-box-arrow-left"></i> Đăng xuất
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <!-- Content -->
        <div class="col-lg-9">
            <div class="content-card">
                <h5><i class="bi bi-box-seam me-2 text-primary"></i>Đơn hàng của tôi</h5>
                
                <!-- Filter tabs -->
                <div class="d-flex gap-2 flex-wrap mb-4">
                    <a asp-action="Orders" class="btn btn-sm @(statusFilter == null ? "btn-brand" : "btn-outline-secondary") rounded-pill px-3">Tất cả</a>
                    <a asp-action="Orders" asp-route-status="@((int)OrderStatus.Pending)" class="btn btn-sm @(statusFilter == OrderStatus.Pending ? "btn-brand" : "btn-outline-secondary") rounded-pill px-3">Chờ xác nhận</a>
                    <a asp-action="Orders" asp-route-status="@((int)OrderStatus.Confirmed)" class="btn btn-sm @(statusFilter == OrderStatus.Confirmed ? "btn-brand" : "btn-outline-secondary") rounded-pill px-3">Đã xác nhận</a>
                    <a asp-action="Orders" asp-route-status="@((int)OrderStatus.Shipping)" class="btn btn-sm @(statusFilter == OrderStatus.Shipping ? "btn-brand" : "btn-outline-secondary") rounded-pill px-3">Đang giao</a>
                    <a asp-action="Orders" asp-route-status="@((int)OrderStatus.Completed)" class="btn btn-sm @(statusFilter == OrderStatus.Completed ? "btn-brand" : "btn-outline-secondary") rounded-pill px-3">Hoàn thành</a>
                    <a asp-action="Orders" asp-route-status="@((int)OrderStatus.Cancelled)" class="btn btn-sm @(statusFilter == OrderStatus.Cancelled ? "btn-brand" : "btn-outline-secondary") rounded-pill px-3">Đã hủy</a>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size:48px;color:#d1d5db"></i>
                        <h6 class="mt-3">Chưa có đơn hàng</h6>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-brand mt-2">Mua sắm ngay</a>
                    </div>
                }
                else
                {
                    @foreach (var order in Model)
                    {
                        <div class="order-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="fw-bold mb-1">Đơn hàng #@order.OrderCode</div>
                                    <div class="text-muted small">Đặt ngày: @order.Created.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                                @switch (order.OrderStatus)
                                {
                                    case OrderStatus.Pending: <span class="badge-status status-pending">Chờ xác nhận</span> break;
                                    case OrderStatus.Confirmed: <span class="badge-status status-confirmed">Đã xác nhận</span> break;
                                    case OrderStatus.Shipping: <span class="badge-status status-shipping">Đang giao</span> break;
                                    case OrderStatus.Completed: <span class="badge-status status-completed">Hoàn thành</span> break;
                                    case OrderStatus.Cancelled: <span class="badge-status status-cancelled">Đã hủy</span> break;
                                }
                            </div>
                            
                            <div class="border-top pt-3">
                                @if (order.OrderDetails != null && order.OrderDetails.Any())
                                {
                                    @foreach (var detail in order.OrderDetails.Take(2))
                                    {
                                        <div class="d-flex align-items-center gap-3 mb-2">
                                            @if (!string.IsNullOrEmpty(detail.Product?.ThumbnailUrl))
                                            {
                                                <img src="@detail.Product.ThumbnailUrl" style="width:50px;height:50px;border-radius:8px;object-fit:cover;border:1px solid #e5e7eb" alt="">
                                            }
                                            else
                                            {
                                                <div style="width:50px;height:50px;border-radius:8px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;border:1px solid #e5e7eb">
                                                    <i class="bi bi-image text-muted"></i>
                                                </div>
                                            }
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold" style="font-size:14px">@detail.Product?.Name</div>
                                                <div class="text-muted small">x @detail.Quantity</div>
                                            </div>
                                            <div class="fw-semibold">@detail.TotalPrice.ToString("N0")₫</div>
                                        </div>
                                    }
                                    @if (order.OrderDetails.Count > 2)
                                    {
                                        <div class="text-muted small">và @(order.OrderDetails.Count - 2) sản phẩm khác...</div>
                                    }
                                }
                            </div>

                            <div class="border-top mt-3 pt-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted me-2">Tổng tiền:</span>
                                    <span class="fw-bold text-primary" style="font-size:18px">@order.TotalAmount.ToString("N0")₫</span>
                                </div>
                                <a asp-action="OrderDetail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</main>
