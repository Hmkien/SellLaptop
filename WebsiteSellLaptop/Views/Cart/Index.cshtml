@using WebsiteSellLaptop.Models.ViewModels
@model CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

@section Styles {
<style>
    .cart-card{background:#fff;border-radius:16px;border:1px solid #e5e7eb;overflow:hidden}
    .cart-header{padding:20px 24px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:between;align-items:center;flex-wrap:wrap;gap:12px}
    .cart-header h5{margin:0;font-weight:700}
    .cart-item{padding:20px 24px;border-bottom:1px solid #f1f3f7;display:flex;gap:16px;align-items:center;flex-wrap:wrap}
    .cart-item:last-child{border-bottom:0}
    .cart-item-img{width:100px;height:100px;border-radius:12px;object-fit:cover;border:1px solid #e5e7eb;flex-shrink:0}
    .cart-item-info{flex:1;min-width:200px}
    .cart-item-title{font-weight:600;font-size:15px;margin-bottom:2px}
    .cart-item-spec{color:var(--muted);font-size:13px;margin-bottom:6px}
    .cart-item-price{font-weight:800;color:var(--brand);font-size:16px}
    .cart-item-old{color:var(--muted);text-decoration:line-through;font-size:13px;margin-left:8px}
    .qty-control{display:inline-flex;align-items:center;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden}
    .qty-btn{width:36px;height:36px;border:none;background:#f8fafc;font-size:16px;font-weight:700;cursor:pointer;color:var(--dark);transition:background .15s}
    .qty-btn:hover{background:#eef2ff;color:var(--brand)}
    .qty-input{width:44px;height:36px;border:none;border-left:1px solid #e5e7eb;border-right:1px solid #e5e7eb;text-align:center;font-weight:600;font-size:14px}
    .btn-remove{color:var(--muted);font-size:18px;background:none;border:none;padding:8px;border-radius:8px;transition:all .15s;cursor:pointer}
    .btn-remove:hover{color:#ef4444;background:#fee2e2}
    .summary-card{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:24px;position:sticky;top:100px}
    .summary-card h5{font-weight:700;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #e5e7eb}
    .summary-row{display:flex;justify-content:space-between;margin-bottom:12px;font-size:14px}
    .summary-row.total{font-size:18px;font-weight:800;border-top:2px solid #e5e7eb;padding-top:16px;margin-top:16px;margin-bottom:0}
    .summary-row.total .total-price{color:var(--brand)}
    .coupon-input{display:flex;gap:8px;margin-bottom:20px}
    .coupon-input input{flex:1;border-radius:10px;border:1px solid #e5e7eb;padding:10px 14px;font-size:14px}
    .btn-checkout{width:100%;padding:14px;border-radius:12px;font-weight:700;font-size:16px;margin-top:16px}
    .btn-continue{display:block;text-align:center;color:var(--brand);font-weight:600;font-size:14px;margin-top:12px}
    .btn-continue:hover{text-decoration:underline;color:#1d4ed8}
    .empty-cart{text-align:center;padding:60px 20px}
    .empty-cart i{font-size:64px;color:#d1d5db;margin-bottom:16px}
    .empty-cart h4{font-weight:700;margin-bottom:8px}
    .empty-cart p{color:var(--muted);margin-bottom:24px}
    .coupon-applied{background:#d1fae5;color:#065f46;padding:10px 14px;border-radius:10px;display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
    .coupon-applied button{background:none;border:none;color:#065f46;font-size:18px;cursor:pointer}
</style>
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Giỏ hàng</li>
        </ol>
    </nav>
</div>

<main class="container mb-5">
    @if (!Model.Items.Any())
    {
        <div class="cart-card">
            <div class="empty-cart">
                <i class="bi bi-cart-x"></i>
                <h4>Giỏ hàng trống</h4>
                <p>Chưa có sản phẩm nào trong giỏ hàng của bạn</p>
                <a asp-controller="Product" asp-action="Index" >
                   Tiếp tục mua sắm
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="cart-card">
                    <div class="cart-header">
                        <h5><i class="bi bi-bag me-2"></i>Giỏ hàng (@Model.TotalItems sản phẩm)</h5>
                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="clearCart()">
                            <i class="bi bi-trash me-1"></i>Xóa tất cả
                        </button>
                    </div>

                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item" data-product-id="@item.ProductId">
                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                            {
                                <img src="@item.ThumbnailUrl" class="cart-item-img" alt="@item.ProductName">
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?auto=format&fit=crop&w=200&q=80" 
                                     class="cart-item-img" alt="@item.ProductName">
                            }

                            <div class="cart-item-info">
                                <div class="cart-item-title">@item.ProductName</div>
                                @if (!string.IsNullOrEmpty(item.Specifications))
                                {
                                    <div class="cart-item-spec">@item.Specifications</div>
                                }
                                <div class="d-flex align-items-center mt-2">
                                    <span class="cart-item-price item-price">@item.Price.ToString("N0")₫</span>
                                    @if (item.DiscountPrice.HasValue && item.DiscountPrice > 0)
                                    {
                                        <span class="cart-item-old">@item.DiscountPrice.Value.ToString("N0")₫</span>
                                    }
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3">
                                <div class="qty-control">
                                    <button class="qty-btn" onclick="changeQuantity('@item.ProductId', -1)">−</button>
                                    <input type="text" class="qty-input" value="@item.Quantity" readonly>
                                    <button class="qty-btn" onclick="changeQuantity('@item.ProductId', 1)">+</button>
                                </div>
                                <button class="btn-remove" onclick="removeItem('@item.ProductId')" title="Xóa">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="summary-card">
                    <h5>Tóm tắt đơn hàng</h5>

                    @if (!string.IsNullOrEmpty(Model.CouponCode))
                    {
                        <div class="coupon-applied">
                            <div>
                                <i class="bi bi-check-circle me-2"></i>
                                <strong>@Model.CouponCode</strong>
                            </div>
                            <button onclick="removeCoupon()" title="Xóa mã"><i class="bi bi-x-lg"></i></button>
                        </div>
                    }
                    else
                    {
                        <div class="coupon-input">
                            <input type="text" id="couponCode" placeholder="Nhập mã giảm giá">
                            <button class="btn btn-outline-primary" onclick="applyCoupon()">Áp dụng</button>
                        </div>
                    }

                    <div class="summary-row">
                        <span class="text-muted">Tạm tính (@Model.TotalItems sp)</span>
                        <span class="fw-semibold" id="totalAmount">@Model.TotalAmount.ToString("N0")₫</span>
                    </div>
                    <div class="summary-row">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="fw-semibold text-success">Miễn phí</span>
                    </div>
                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="summary-row">
                            <span class="text-muted">Giảm giá</span>
                            <span class="fw-semibold text-danger" id="discountAmount">-@Model.DiscountAmount.ToString("N0")₫</span>
                        </div>
                    }
                    <div class="summary-row total">
                        <span>Tổng cộng</span>
                        <span class="total-price" id="finalAmount">@Model.FinalAmount.ToString("N0")₫</span>
                    </div>

                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-brand btn-checkout">
                        Tiến hành thanh toán <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                    <a asp-controller="Product" asp-action="Index" class="btn-continue">
                        <i class="bi bi-arrow-left me-1"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    }
</main>

@section Scripts {
<script>
    function changeQuantity(productId, delta) {
        const cartItem = document.querySelector(`[data-product-id="${productId}"]`);
        const qtyInput = cartItem.querySelector('.qty-input');
        let newQty = parseInt(qtyInput.value) + delta;
        
        if (newQty < 1) newQty = 1;
        if (newQty > 99) newQty = 99;

        $.post('@Url.Action("UpdateQuantity", "Cart")', {
            productId: productId,
            quantity: newQty
        }, function(response) {
            if (response.success) {
                qtyInput.value = newQty;
                $('#totalAmount').text(response.totalAmount + '₫');
                $('#finalAmount').text(response.finalAmount + '₫');
                updateCartBadge();
            }
        });
    }

    function removeItem(productId) {
        if (!confirm('Bạn có chắc muốn xóa sản phẩm này?')) return;

        $.post('@Url.Action("RemoveItem", "Cart")', {
            productId: productId
        }, function(response) {
            if (response.success) {
                $(`[data-product-id="${productId}"]`).fadeOut(300, function() {
                    $(this).remove();
                    if (response.cartCount === 0) {
                        location.reload();
                    } else {
                        $('#totalAmount').text(response.totalAmount + '₫');
                        $('#finalAmount').text(response.finalAmount + '₫');
                        $('.cart-header h5').html(`<i class="bi bi-bag me-2"></i>Giỏ hàng (${response.cartCount} sản phẩm)`);
                        updateCartBadge();
                    }
                });
            }
        });
    }

    function clearCart() {
        if (!confirm('Bạn có chắc muốn xóa tất cả sản phẩm?')) return;

        $.post('@Url.Action("ClearCart", "Cart")', function(response) {
            if (response.success) {
                location.reload();
            }
        });
    }

    function applyCoupon() {
        const code = $('#couponCode').val().trim();
        if (!code) {
            alert('Vui lòng nhập mã giảm giá');
            return;
        }

        $.post('@Url.Action("ApplyCoupon", "Cart")', {
            code: code
        }, function(response) {
            if (response.success) {
                alert(response.message);
                location.reload();
            } else {
                alert(response.message);
            }
        });
    }

    function removeCoupon() {
        $.post('@Url.Action("RemoveCoupon", "Cart")', function(response) {
            if (response.success) {
                location.reload();
            }
        });
    }

    function updateCartBadge() {
        $.get('@Url.Action("GetCartCount", "Cart")', function(count) {
            $('.icon-badge').text(count);
        });
    }
</script>
}
