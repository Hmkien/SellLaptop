<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin PQAtech.vn</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        :root {
            --sidebar-w: 260px;
            --brand: #0ea5e9;
            --brand-dark: #0284c7;
            --dark: #0f172a;
            --sidebar-bg: linear-gradient(180deg,#0f172a 0%,#1e293b 100%);
            --sidebar-hover: rgba(14,165,233,.1);
            --sidebar-active: linear-gradient(135deg,#0ea5e9,#3b82f6);
            --bg: #f8fafc;
            --card: #ffffff;
            --muted: #64748b;
            --border: #e2e8f0;
        }
        * { box-sizing: border-box; }
        body { font-family: 'Manrope', system-ui, sans-serif; margin: 0; background: var(--bg); color: var(--dark); line-height: 1.6; }
        a { text-decoration: none; }

        /* ── Sidebar ── */
        .admin-sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: var(--sidebar-w); background: var(--sidebar-bg);
            display: flex; flex-direction: column; z-index: 1040;
            transition: transform .25s; box-shadow: 2px 0 20px rgba(14,165,233,.08);
        }
        .sidebar-brand {
            padding: 24px 20px 20px;
            display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-brand .logo-icon {
            width: 38px; height: 38px; border-radius: 10px;
            background: var(--brand); display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 18px; font-weight: 800;
        }
        .sidebar-brand span { color: #fff; font-size: 18px; font-weight: 700; }

        .sidebar-menu { flex: 1; padding: 16px 12px; overflow-y: auto; direction: rtl; }
        .sidebar-menu > * { direction: ltr; }

        /* Custom scrollbar - thin & on left side */
        .sidebar-menu::-webkit-scrollbar { width: 4px; }
        .sidebar-menu::-webkit-scrollbar-track { background: transparent; }
        .sidebar-menu::-webkit-scrollbar-thumb { 
            background: rgba(255,255,255,.15); 
            border-radius: 10px;
        }
        .sidebar-menu::-webkit-scrollbar-thumb:hover { 
            background: rgba(255,255,255,.25); 
        }

        .sidebar-menu .menu-label {
            font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
            color: rgba(255,255,255,.35); padding: 12px 12px 6px; font-weight: 700;
        }
        .sidebar-menu .menu-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 14px; border-radius: 10px; color: rgba(255,255,255,.65);
            font-size: 14px; font-weight: 500; margin-bottom: 2px; transition: all .2s;
        }
        .sidebar-menu .menu-item:hover { background: var(--sidebar-hover); color: #fff; transform: translateX(4px); }
        .sidebar-menu .menu-item.active { background: var(--sidebar-active); color: #fff; font-weight: 600; box-shadow: 0 4px 12px rgba(14,165,233,.25); }
        .sidebar-menu .menu-item i { width: 20px; text-align: center; font-size: 16px; }

        .sidebar-footer {
            padding: 16px 20px; border-top: 1px solid rgba(255,255,255,.08);
            display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,.6); font-size: 13px;
        }
        .sidebar-footer .avatar-sm {
            width: 34px; height: 34px; border-radius: 50%; 
            background: linear-gradient(135deg,#0ea5e9,#3b82f6);
            display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px;
        }

        /* ── Main ── */
        .admin-main { margin-left: var(--sidebar-w); min-height: 100vh; display: flex; flex-direction: column; }

        /* ── Topbar ── */
        .admin-topbar {
            background: var(--card); border-bottom: 1px solid var(--border);
            padding: 0 28px; height: 64px; display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 1030;
        }
        .topbar-search { position: relative; width: 300px; }
        .topbar-search input {
            width: 100%; border-radius: 10px; border: 1px solid var(--border);
            padding: 8px 14px 8px 38px; background: #f8fafc; font-size: 14px;
        }
        .topbar-search input:focus { border-color: var(--brand); outline: none; box-shadow: 0 0 0 3px rgba(37,99,235,.12); }
        .topbar-search i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); }
        .topbar-actions { display: flex; align-items: center; gap: 8px; }
        .topbar-btn {
            width: 38px; height: 38px; border-radius: 10px; border: 1px solid var(--border);
            background: #f8fafc; display: flex; align-items: center; justify-content: center;
            color: var(--dark); font-size: 16px; position: relative; cursor: pointer; transition: all .15s;
        }
        .topbar-btn:hover { background: #eef2ff; color: var(--brand); border-color: var(--brand); }
        .topbar-dot {
            position: absolute; top: -2px; right: -2px; width: 8px; height: 8px;
            border-radius: 50%; background: #ef4444; border: 2px solid var(--card);
        }

        /* ── Content ── */
        .admin-content { flex: 1; padding: 28px; }

        /* ── Cards / Tables ── */
        .admin-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 14px; overflow: hidden;
        }
        .admin-card-header {
            padding: 18px 24px;
            display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
            border-bottom: 1px solid var(--border);
        }
        .admin-card-header h5 { margin: 0; font-weight: 700; font-size: 16px; }
        .admin-card-body { padding: 0; }

        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table thead th {
            background: #f8fafc; padding: 12px 16px;
            font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
            color: var(--muted); border-bottom: 1px solid var(--border); white-space: nowrap;
        }
        .admin-table tbody td {
            padding: 14px 16px; border-bottom: 1px solid #f3f4f6;
            font-size: 14px; vertical-align: middle;
        }
        .admin-table tbody tr:last-child td { border-bottom: 0; }
        .admin-table tbody tr:hover { background: #fafbfd; }

        .record-title {
            color: var(--dark); font-weight: 600; cursor: pointer; transition: color .15s;
        }
        .record-title:hover { color: var(--brand); }

        /* ── Status badges ── */
        .badge-status { padding: 4px 12px; border-radius: 50rem; font-size: 12px; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; }
        .badge-approved { background: #dcfce7; color: #16a34a; }
        .badge-pending { background: #fef3c7; color: #d97706; }
        .badge-rejected { background: #fee2e2; color: #dc2626; }
        .badge-draft { background: #f1f3f7; color: #6b7280; }

        /* ── Action icons ── */
        .action-icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 32px; height: 32px; border-radius: 8px;
            font-size: 14px; cursor: pointer; transition: all .15s;
            color: var(--muted); background: transparent;
        }
        .action-icon:hover { background: #f1f3f7; }
        .action-approve { color: #16a34a; }
        .action-approve:hover { background: #dcfce7; color: #16a34a; }
        .action-reject { color: #d97706; }
        .action-reject:hover { background: #fef3c7; color: #d97706; }
        .action-edit { color: var(--brand); }
        .action-edit:hover { background: #eef2ff; color: var(--brand); }
        .action-delete { color: #ef4444; }
        .action-delete:hover { background: #fee2e2; color: #ef4444; }

        /* ── Pagination ── */
        .admin-pagination { padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); }
        .pg-info { font-size: 13px; color: var(--muted); }
        .pg-list { display: flex; gap: 4px; }
        .pg-list a, .pg-list span {
            width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 600; border: 1px solid var(--border); background: #fff;
            color: var(--dark); transition: all .15s;
        }
        .pg-list a:hover { background: #eef2ff; border-color: var(--brand); color: var(--brand); }
        .pg-list .active span { background: var(--brand); color: #fff; border-color: var(--brand); }
        .pg-list .disabled span { color: #d1d5db; background: #fafafa; cursor: default; }

        /* ── Stat cards ── */
        .stat-card {
            background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 20px;
            display: flex; align-items: center; gap: 16px;
        }
        .stat-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center; font-size: 22px;
        }
        .stat-info .stat-value { font-size: 24px; font-weight: 800; line-height: 1.2; }
        .stat-info .stat-label { font-size: 13px; color: var(--muted); }

        /* ── Buttons ── */
        .btn-brand { background: var(--brand); color: #fff; border: none; border-radius: 10px; font-weight: 600; font-size: 14px; }
        .btn-brand:hover { background: var(--brand-dark); color: #fff; }

        /* ── Responsive ── */
        .sidebar-toggle { display: none; background: none; border: none; font-size: 22px; color: var(--dark); cursor: pointer; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1035; }
        @@media (max-width: 991px) {
            .admin-sidebar { transform: translateX(-100%); box-shadow: 4px 0 12px rgba(0,0,0,0.15); }
            .admin-sidebar.open { transform: translateX(0); }
            .admin-main { margin-left: 0; }
            .sidebar-toggle { display: block; }
            .sidebar-overlay.show { display: block; }
            .topbar-search { width: 200px; }
            .admin-content { padding: 16px; }
            .stat-card { font-size: 13px; padding: 14px; }
            .stat-icon { width: 40px; height: 40px; font-size: 18px; }
            .stat-value { font-size: 20px; }
            .admin-table { font-size: 13px; }
            .admin-table thead th, .admin-table tbody td { padding: 10px 12px; }
            .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        }
        @@media (max-width: 576px) {
            .topbar-search { display: none; }
            .admin-topbar { padding: 0 16px; }
            .stat-card { padding: 12px; }
            .stat-icon { width: 36px; height: 36px; font-size: 16px; }
            .stat-value { font-size: 18px; }
        }

        /* ── File Upload ── */
        .file-upload-area {
            border: 2px dashed var(--border);
            border-radius: 14px;
            padding: 40px 20px;
            text-align: center;
            background: #fafbfc;
            cursor: pointer;
            transition: all 0.3s;
        }
        .file-upload-area:hover {
            border-color: var(--brand);
            background: #f8faff;
        }
        .file-upload-area.dragover {
            border-color: var(--brand);
            background: #eef2ff;
        }
        .preview-container {
            position: relative;
            display: inline-block;
        }
        .preview-img {
            max-width: 100%;
            max-height: 200px;
            border-radius: 12px;
            border: 2px solid var(--border);
        }
        .preview-remove {
            position: absolute;
            top: -8px;
            right: -8px;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #ef4444;
            color: #fff;
            border: 2px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 14px;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="logo-icon" style="background:linear-gradient(135deg,#0ea5e9,#3b82f6)">P</div>
            <span>PQAtech.vn</span>
        </div>
        <nav class="sidebar-menu">
            <div class="menu-label">Tổng quan</div>
            <a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            <div class="menu-label">Báo cáo</div>
            <a href="@Url.Action("Index", "Report", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-graph-up-arrow"></i> Tổng quan
            </a>
            <a href="@Url.Action("Revenue", "Report", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Revenue" ? "active" : "")">
                <i class="bi bi-currency-dollar"></i> Doanh thu
            </a>
            <a href="@Url.Action("Inventory", "Report", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Inventory" ? "active" : "")">
                <i class="bi bi-box-seam"></i> Tồn kho
            </a>

            <div class="menu-label">Sản phẩm</div>
            <a href="@Url.Action("Index", "Category", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                <i class="bi bi-folder-fill"></i> Danh mục
            </a>
            <a href="@Url.Action("Index", "Brand", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Brand" ? "active" : "")">
                <i class="bi bi-award-fill"></i> Thương hiệu
            </a>
            <a href="@Url.Action("Index", "Product", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                <i class="bi bi-laptop-fill"></i> Sản phẩm
            </a>

            <div class="menu-label">Đơn hàng</div>
            <a href="@Url.Action("Index", "Order", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                <i class="bi bi-receipt"></i> Đơn hàng
            </a>
            <a href="@Url.Action("Index", "Coupon", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Coupon" ? "active" : "")">
                <i class="bi bi-ticket-perforated-fill"></i> Mã giảm giá
            </a>

            <div class="menu-label">Nội dung</div>
            <a href="@Url.Action("Index", "Blog", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")">
                <i class="bi bi-journal-richtext"></i> Bài viết
            </a>
            <a href="@Url.Action("Index", "Banner", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Banner" ? "active" : "")">
                <i class="bi bi-images"></i> Banner
            </a>
            <a href="@Url.Action("Index", "Contact", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")">
                <i class="bi bi-envelope"></i> Liên hệ
            </a>

            <div class="menu-label">Hệ thống</div>
            <a href="@Url.Action("Index", "User", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                <i class="bi bi-people-fill"></i> Người dùng
            </a>
            <a href="@Url.Action("Index", "Role", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Role" ? "active" : "")">
                <i class="bi bi-person-badge-fill"></i> Vai trò
            </a>
            <a href="@Url.Action("Index", "Partner", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Partner" ? "active" : "")">
                <i class="bi bi-building"></i> Đối tác
            </a>
            <a href="@Url.Action("Index", "Contact", new { area = "Admin" })" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")">
                <i class="bi bi-envelope-fill"></i> Liên hệ
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="avatar-sm">A</div>
            <div>
                <div class="text-white fw-semibold" style="font-size:13px">@User.Identity?.Name</div>
                <div style="font-size:11px">Quản trị viên</div>
            </div>
        </div>
    </aside>

    <!-- Main -->
    <div class="admin-main">
        <!-- Topbar -->
        <header class="admin-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="sidebar-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tìm kiếm...">
                </div>
            </div>
            <div class="topbar-actions">
                <a href="/" class="topbar-btn" title="Xem website"><i class="bi bi-box-arrow-up-right"></i></a>
                <div class="topbar-btn"><i class="bi bi-bell"></i><span class="topbar-dot"></span></div>
                <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" style="margin:0">
                    <button type="submit" class="topbar-btn" title="Đăng xuất"><i class="bi bi-box-arrow-right"></i></button>
                </form>
            </div>
        </header>

        <!-- Content -->
        <main class="admin-content">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
