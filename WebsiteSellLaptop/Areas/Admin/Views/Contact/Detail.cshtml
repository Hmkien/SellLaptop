@model Contact
@using WebsiteSellLaptop.Models.Enums

@{
    ViewData["Title"] = "Chi tiết liên hệ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-envelope-open me-2"></i>Chi tiết liên hệ</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="admin-card p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h5 class="fw-bold mb-0">@Model.Subject</h5>
                @switch (Model.Status)
                {
                    case StatusEntity.Approved: <span class="badge-status approved">Đã xử lý</span> break;
                    case StatusEntity.Pending: <span class="badge-status pending">Chờ xử lý</span> break;
                    case StatusEntity.Rejected: <span class="badge-status rejected">Đã từ chối</span> break;
                }
            </div>
            
            <div class="border-bottom pb-3 mb-3">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle text-muted"></i>
                        <strong>@Model.FullName</strong>
                    </div>
                    <div class="d-flex align-items-center gap-2 text-muted">
                        <i class="bi bi-envelope"></i>
                        <span>@Model.Email</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="d-flex align-items-center gap-2 text-muted">
                            <i class="bi bi-telephone"></i>
                            <span>@Model.Phone</span>
                        </div>
                    }
                </div>
                <div class="text-muted small">
                    <i class="bi bi-clock"></i> Gửi lúc: @Model.Created.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <div class="message-content">
                <h6 class="fw-semibold mb-2">Nội dung:</h6>
                <div class="p-3 bg-light rounded" style="white-space: pre-wrap;">@Model.Message</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-1"></i>Thông tin</h6>
            <table class="table table-borderless mb-0">
                <tr><th width="110">Mã:</th><td><code>@Model.Code</code></td></tr>
                <tr>
                    <th>Đã đọc:</th>
                    <td>
                        @if (Model.IsRead)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success">Đã đọc</span>
                        }
                        else
                        {
                            <span class="badge bg-warning bg-opacity-10 text-warning">Chưa đọc</span>
                        }
                    </td>
                </tr>
                <tr><th>Ngày tạo:</th><td>@Model.Created.ToString("dd/MM/yyyy HH:mm")</td></tr>
                <tr><th>Cập nhật:</th><td>@Model.LastModified.ToString("dd/MM/yyyy HH:mm")</td></tr>
            </table>
        </div>

        <div class="admin-card p-4 mt-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-gear me-1"></i>Thao tác</h6>
            <div class="d-grid gap-2">
                @if (Model.Status == StatusEntity.Pending)
                {
                    <button type="button" class="btn btn-success" onclick="confirmApprove()">
                        <i class="bi bi-check-circle me-1"></i>Đánh dấu đã xử lý
                    </button>
                    <button type="button" class="btn btn-outline-danger" onclick="confirmReject()">
                        <i class="bi bi-x-circle me-1"></i>Từ chối
                    </button>
                }
                    <button type="button" class="btn btn-outline-secondary" onclick="confirmDelete()">
                        <i class="bi bi-trash me-1"></i>Xóa liên hệ
                    </button>
               
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-success"><i class="bi bi-check-circle me-2"></i>Xác nhận</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Đánh dấu liên hệ này đã được xử lý?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-success">Xác nhận</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger"><i class="bi bi-x-circle me-2"></i>Từ chối</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Từ chối liên hệ này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Reject" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger">Từ chối</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Xóa liên hệ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa liên hệ này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmApprove() { new bootstrap.Modal(document.getElementById('approveModal')).show(); }
    function confirmReject() { new bootstrap.Modal(document.getElementById('rejectModal')).show(); }
    function confirmDelete() { new bootstrap.Modal(document.getElementById('deleteModal')).show(); }
</script>
}
