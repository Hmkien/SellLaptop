@model List<Category>
@using WebsiteSellLaptop.Models.Enums

@{
    ViewData["Title"] = "Quản lý danh mục";
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var totalItems = ViewBag.TotalItems ?? 0;
    var pageSize = ViewBag.PageSize ?? 10;
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-grid me-2"></i>Quản lý danh mục</h4>
    <button class="btn btn-brand" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg me-1"></i>Thêm mới
    </button>
</div>

<!-- Search Form -->
<div class="admin-card mb-4">
    <form method="get" class="row g-3 align-items-end p-3">
        <div class="col-md-11">
            <label class="form-label fw-semibold">Tìm kiếm</label>
            <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Nhập mã hoặc tên danh mục...">
        </div>
        <div class="col-md-1 text-center">
            <i class="bi bi-search" style="font-size:24px;color:var(--brand);cursor:pointer" onclick="this.closest('form').submit()" title="Tìm kiếm"></i>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="admin-card p-0">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th width="60">STT</th>
                    <th width="100">Mã</th>
                    <th width="150">Tên danh mục</th>
                    <th width ="150">  Ảnh</th>
                    <th width="140">Trạng thái</th>
                    <th width="150">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Không có dữ liệu</td></tr>
                }
                else
                {
                    var sttBase = (currentPage - 1) * pageSize;
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var item = Model[i];
                        var stt = sttBase + i + 1;
                        <tr>
                            <td class="text-center">@stt</td>
                           
                            <td>
                                <a href="javascript:void(0)" onclick="showDetail('@item.Id')" class="text-primary fw-semibold">@item.Code</a>
                            </td>
                            <td>
                                <a href="javascript:void(0)" onclick="showDetail('@item.Id')" class="text-primary fw-semibold">@item.Name</a>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <div class="text-muted small mt-1" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@item.Description</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" style="width:50px;height:50px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb" />
                                }
                                else
                                {
                                    <div style="width:50px;height:50px;background:#f1f3f7;border-radius:8px;display:flex;align-items:center;justify-content:center;border:1px solid #e5e7eb">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                @switch (item.Status)
                                {
                                    case StatusEntity.Approved: 
                                        <span style="display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:20px;font-size:13px;font-weight:600;background:linear-gradient(135deg, #10b981 0%, #059669 100%);color:white;box-shadow:0 2px 8px rgba(16,185,129,0.3)">
                                            <i class="bi bi-check-circle-fill"></i>Đã duyệt
                                        </span>
                                        break;
                                    case StatusEntity.Pending: 
                                        <span style="display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:20px;font-size:13px;font-weight:600;background:linear-gradient(135deg, #f59e0b 0%, #d97706 100%);color:white;box-shadow:0 2px 8px rgba(245,158,11,0.3)">
                                            <i class="bi bi-clock-fill"></i>Chờ duyệt
                                        </span>
                                        break;
                                    case StatusEntity.Rejected: 
                                        <span style="display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:20px;font-size:13px;font-weight:600;background:linear-gradient(135deg, #ef4444 0%, #dc2626 100%);color:white;box-shadow:0 2px 8px rgba(239,68,68,0.3)">
                                            <i class="bi bi-x-circle-fill"></i>Hủy duyệt
                                        </span>
                                        break;
                                    case StatusEntity.Draft: 
                                        <span style="display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:20px;font-size:13px;font-weight:600;background:linear-gradient(135deg, #6b7280 0%, #4b5563 100%);color:white;box-shadow:0 2px 8px rgba(107,114,128,0.3)">
                                            <i class="bi bi-pencil-fill"></i>Nháp
                                        </span>
                                        break;
                                }
                            </td>
                          
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    @if (item.Status == StatusEntity.Approved)
                                    {
                                        <i class="bi bi-x-circle-fill" style="font-size:22px;color:#f59e42;cursor:pointer" title="Hủy duyệt" onclick="doReject('@item.Id')"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle-fill" style="font-size:22px;color:#22c55e;cursor:pointer" title="Duyệt" onclick="doApprove('@item.Id')"></i>
                                        <i class="bi bi-pencil-square" style="font-size:22px;color:#2563eb;cursor:pointer" title="Sửa" onclick="openEditModal('@item.Id')"></i>
                                        <i class="bi bi-trash3-fill" style="font-size:22px;color:#ef4444;cursor:pointer" title="Xóa vĩnh viễn" onclick="confirmDelete('@item.Id', '@item.Name')"></i>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="admin-pagination">
            <div class="pg-info">
                Hiển thị @(((currentPage - 1) * pageSize) + 1) - @Math.Min(currentPage * pageSize, totalItems) / @totalItems bản ghi
            </div>
            <div class="pg-list">
                @if (currentPage > 1)
                {
                    <a href="@Url.Action("Index", new { page = 1, keyword })">«</a>
                    <a href="@Url.Action("Index", new { page = currentPage - 1, keyword })">‹</a>
                }
                else
                {
                    <span class="disabled">«</span>
                    <span class="disabled">‹</span>
                }

                @{
                    var start = Math.Max(1, currentPage - 2);
                    var end = Math.Min(totalPages, currentPage + 2);
                }
                @for (int p = start; p <= end; p++)
                {
                    if (p == currentPage)
                    {
                        <span class="active">@p</span>
                    }
                    else
                    {
                        <a href="@Url.Action("Index", new { page = p, keyword })">@p</a>
                    }
                }

                @if (currentPage < totalPages)
                {
                    <a href="@Url.Action("Index", new { page = currentPage + 1, keyword })">›</a>
                    <a href="@Url.Action("Index", new { page = totalPages, keyword })">»</a>
                }
                else
                {
                    <span class="disabled">›</span>
                    <span class="disabled">»</span>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Thêm mới -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="createForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createModalLabel"><i class="bi bi-plus-circle me-2"></i>Thêm mới danh mục</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Mã danh mục <span class="text-danger">*</span></label>
                            <input type="text" name="Code" class="form-control" required maxlength="50" placeholder="VD: LAPTOP, GAMING..." style="text-transform:uppercase">
                            <small class="text-muted">Mã sẽ tự động viết hoa</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tên danh mục <span class="text-danger">*</span></label>
                            <input type="text" name="Name" class="form-control" required maxlength="200" placeholder="Nhập tên danh mục">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Thứ tự</label>
                            <input type="number" name="SortOrder" class="form-control" value="0" min="0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ảnh URL (Tùy chọn)</label>
                            <input type="text" name="ImageUrl" class="form-control" placeholder="https://...">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mô tả</label>
                            <textarea name="Description" class="form-control" rows="3" placeholder="Nhập mô tả danh mục"></textarea>
                        </div>

                        <!-- Upload ảnh ở cuối form -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Hoặc tải ảnh từ máy tính</label>
                            <input type="file" id="createImageFile" name="imageFile" accept="image/*" class="d-none" onchange="previewCreateImage(this)">
                            <div class="file-upload-area" style="padding:30px" onclick="document.getElementById('createImageFile').click()">
                                <div id="createImagePreview">
                                    <i class="bi bi-cloud-upload" style="font-size:36px;color:var(--brand)"></i>
                                    <p class="mb-1 fw-semibold mt-2">Click để tải ảnh lên</p>
                                    <p class="text-muted small mb-0">JPG, PNG, GIF, WEBP (Max 5MB)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-brand">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="editForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel"><i class="bi bi-pencil-square me-2"></i>Sửa danh mục</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Mã danh mục <span class="text-danger">*</span></label>
                            <input type="text" name="Code" id="editCode" class="form-control" required maxlength="50" style="text-transform:uppercase">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tên danh mục <span class="text-danger">*</span></label>
                            <input type="text" name="Name" id="editName" class="form-control" required maxlength="200">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Thứ tự</label>
                            <input type="number" name="SortOrder" id="editSortOrder" class="form-control" min="0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ảnh URL (Tùy chọn)</label>
                            <input type="text" name="ImageUrl" id="editImageUrl" class="form-control">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mô tả</label>
                            <textarea name="Description" id="editDescription" class="form-control" rows="3"></textarea>
                        </div>

                        <!-- Current Image -->
                        <div class="col-12" id="editCurrentImageContainer" style="display:none">
                            <label class="form-label fw-semibold">Ảnh hiện tại</label>
                            <div class="mb-2">
                                <img id="editCurrentImage" src="" style="max-height:120px;border-radius:8px;border:1px solid #e5e7eb">
                            </div>
                        </div>

                        <!-- Upload ảnh mới -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Thay đổi ảnh</label>
                            <input type="file" id="editImageFile" name="imageFile" accept="image/*" class="d-none" onchange="previewEditImage(this)">
                            <div class="file-upload-area" style="padding:30px" onclick="document.getElementById('editImageFile').click()">
                                <div id="editImagePreview">
                                    <i class="bi bi-cloud-upload" style="font-size:36px;color:var(--brand)"></i>
                                    <p class="mb-1 fw-semibold mt-2">Click để tải ảnh mới</p>
                                    <p class="text-muted small mb-0">JPG, PNG, GIF, WEBP (Max 5MB)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn btn-brand">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Xem chi tiết -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalLabel"><i class="bi bi-info-circle me-2"></i>Chi tiết danh mục</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Ảnh + tên -->
                <div id="detailImageContainer" class="text-center mb-4" style="display:none">
                    <img id="detailImage" src="" alt=""
                         style="max-height:160px;max-width:260px;border-radius:12px;border:1px solid #e5e7eb;object-fit:contain;background:#f8fafc;padding:8px">
                </div>

                <!-- Info grid -->
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-upc me-1"></i>Mã danh mục</div>
                            <div class="fw-bold" id="detailCode"></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-tag me-1"></i>Tên danh mục</div>
                            <div class="fw-bold" id="detailName"></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-link-45deg me-1"></i>Slug</div>
                            <div id="detailSlug" class="text-primary small"></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-sort-numeric-up me-1"></i>Thứ tự</div>
                            <div id="detailSortOrder"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-card-text me-1"></i>Mô tả</div>
                            <div id="detailDescription"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-image me-1"></i>Ảnh URL</div>
                            <div id="detailImageUrl" class="small" style="word-break:break-all;color:#64748b"></div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-circle-fill me-1"></i>Trạng thái</div>
                            <div id="detailStatus"></div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-calendar-plus me-1"></i>Ngày tạo</div>
                            <div id="detailCreated" class="small"></div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
                            <div class="text-muted small mb-1"><i class="bi bi-calendar-check me-1"></i>Cập nhật</div>
                            <div id="detailLastModified" class="small"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xác nhận xóa -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Xác nhận xóa vĩnh viễn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    <strong>Cảnh báo:</strong> Hành động này sẽ xóa vĩnh viễn dữ liệu khỏi hệ thống!
                </div>
                <p>Bạn có chắc chắn muốn xóa danh mục <strong id="deleteItemName"></strong>?</p>
                <p class="text-muted small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    Nếu danh mục có sản phẩm, bạn sẽ không thể xóa.
                </p>
            </div>
            <div class="modal-footer">
                <input type="hidden" id="deleteItemId">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
                <button type="button" class="btn btn-danger" onclick="doDelete()">
                    <i class="bi bi-trash3-fill"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast thông báo -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
    <div id="toast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="bi" id="toastIcon" style="font-size:20px"></i>
                <span id="toastMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const baseUrl = '@Url.Action("Index", "Category", new { area = "Admin" })'.replace('/Index', '');
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    // Image Preview Functions
    function previewCreateImage(input) {
        const preview = document.getElementById('createImagePreview');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.innerHTML = `
                    <div class="preview-container">
                        <img src="${e.target.result}" class="preview-img" style="max-height:150px">
                        <button type="button" class="preview-remove" onclick="removeCreateImage()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                `;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function removeCreateImage() {
        document.getElementById('createImageFile').value = '';
        document.getElementById('createImagePreview').innerHTML = `
            <i class="bi bi-cloud-upload" style="font-size:36px;color:var(--brand)"></i>
            <p class="mb-1 fw-semibold mt-2">Click để tải ảnh lên</p>
            <p class="text-muted small mb-0">JPG, PNG, GIF (Max 5MB)</p>
        `;
    }

    function previewEditImage(input) {
        const preview = document.getElementById('editImagePreview');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.innerHTML = `
                    <div class="preview-container">
                        <img src="${e.target.result}" class="preview-img" style="max-height:150px">
                        <button type="button" class="preview-remove" onclick="removeEditImage()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                `;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function removeEditImage() {
        document.getElementById('editImageFile').value = '';
        document.getElementById('editImagePreview').innerHTML = `
            <i class="bi bi-cloud-upload" style="font-size:36px;color:var(--brand)"></i>
            <p class="mb-1 fw-semibold mt-2">Click để tải ảnh mới</p>
            <p class="text-muted small mb-0">JPG, PNG, GIF (Max 5MB)</p>
        `;
    }

    function showToast(message, type = 'success') {
        const toast = document.getElementById('toast');
        const toastIcon = document.getElementById('toastIcon');
        const toastMessage = document.getElementById('toastMessage');

        toast.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'text-white');
        toastIcon.classList.remove('bi-check-circle-fill', 'bi-x-circle-fill', 'bi-exclamation-triangle-fill');

        if (type === 'success') {
            toast.classList.add('bg-success', 'text-white');
            toastIcon.classList.add('bi-check-circle-fill');
        } else if (type === 'error') {
            toast.classList.add('bg-danger', 'text-white');
            toastIcon.classList.add('bi-x-circle-fill');
        } else {
            toast.classList.add('bg-warning', 'text-dark');
            toastIcon.classList.add('bi-exclamation-triangle-fill');
        }

        toastMessage.textContent = message;
        const bsToast = new bootstrap.Toast(toast);
        bsToast.show();
    }

    document.getElementById('createForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);

        const response = await fetch(`${baseUrl}/Create`, {
