@using WebsiteSellLaptop.Models.Enums

@{
    ViewData["Title"] = "Báo cáo tổng quan";
    DateTime fromDate = ViewBag.FromDate;
    DateTime toDate = ViewBag.ToDate;

    var totalOrders = (int)(ViewBag.TotalOrders ?? 0);
    var totalRevenue = (decimal)(ViewBag.TotalRevenue ?? 0m);
    var completedOrders = (int)(ViewBag.CompletedOrders ?? 0);
    var cancelledOrders = (int)(ViewBag.CancelledOrders ?? 0);

    var pendingOrders = (int)(ViewBag.PendingOrders ?? 0);
    var confirmedOrders = (int)(ViewBag.ConfirmedOrders ?? 0);
    var shippingOrders = (int)(ViewBag.ShippingOrders ?? 0);

    var topProducts = ViewBag.TopProducts as List<dynamic> ?? new List<dynamic>();
    var chartLabels = ViewBag.ChartLabels as List<string> ?? new List<string>();
    var chartValues = ViewBag.ChartValues as List<decimal> ?? new List<decimal>();
    var chartOrders = ViewBag.ChartOrders as List<int> ?? new List<int>();
}

@section Styles {
<style>
    .report-stat{background:#fff;border-radius:16px;padding:24px;border:1px solid #e5e7eb;transition:all .2s}
    .report-stat:hover{box-shadow:0 4px 20px rgba(0,0,0,.08);transform:translateY(-2px)}
    .report-stat .icon{width:56px;height:56px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:16px}
    .report-stat .icon.blue{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff}
    .report-stat .icon.green{background:linear-gradient(135deg,#10b981 0%,#059669 100%);color:#fff}
    .report-stat .icon.orange{background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%);color:#fff}
    .report-stat .icon.red{background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);color:#fff}
    .report-stat .label{color:#6b7280;font-size:14px;font-weight:500;margin-bottom:8px}
    .report-stat .value{font-size:28px;font-weight:700;color:#111827;margin-bottom:4px}
    .chart-card{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:24px}
    .chart-card h6{font-weight:700;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #e5e7eb}
    .date-filter{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:20px;margin-bottom:24px}
    .date-filter .btn-quick{border-radius:8px;font-size:13px;font-weight:600;padding:6px 16px;border:1px solid #e5e7eb;background:#f9fafb;color:#374151;transition:all .15s}
    .date-filter .btn-quick:hover,.date-filter .btn-quick.active{background:var(--brand);color:#fff;border-color:var(--brand)}
    .order-status-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px}
    .status-card{background:#fff;border-radius:12px;border:1px solid #e5e7eb;padding:16px;text-align:center}
    .status-card .count{font-size:32px;font-weight:700;margin-bottom:8px}
    .status-card .label{font-size:13px;color:#6b7280;font-weight:500}
    .status-card.pending .count{color:#f59e0b}
    .status-card.confirmed .count{color:#3b82f6}
    .status-card.shipping .count{color:#8b5cf6}
    .status-card.completed .count{color:#10b981}
    .status-card.cancelled .count{color:#ef4444}
    .product-item{display:flex;gap:12px;padding:12px;border-radius:8px;transition:background .15s}
    .product-item:hover{background:#f9fafb}
    .product-item img{width:60px;height:60px;border-radius:8px;object-fit:cover;border:1px solid #e5e7eb}
    .product-item .info{flex:1}
    .product-item .name{font-weight:600;font-size:14px;margin-bottom:4px}
    .product-item .stats{font-size:13px;color:#6b7280}
    .report-nav{display:flex;gap:8px;margin-bottom:24px}
    .report-nav a{padding:10px 20px;border-radius:10px;font-weight:600;font-size:14px;border:1px solid #e5e7eb;color:#374151;transition:all .15s}
    .report-nav a:hover{border-color:var(--brand);color:var(--brand)}
    .report-nav a.active{background:var(--brand);color:#fff;border-color:var(--brand)}
</style>
}

<!-- Navigation -->
<div class="report-nav">
    <a href="@Url.Action("Index", "Report", new { area = "Admin", fromDate = fromDate.ToString("yyyy-MM-dd"), toDate = toDate.ToString("yyyy-MM-dd") })" class="active">
        <i class="bi bi-grid-1x2 me-1"></i>Tổng quan
    </a>
    <a href="@Url.Action("Revenue", "Report", new { area = "Admin" })">
        <i class="bi bi-currency-dollar me-1"></i>Doanh thu
    </a>
    <a href="@Url.Action("Inventory", "Report", new { area = "Admin" })">
        <i class="bi bi-box-seam me-1"></i>Tồn kho
    </a>
</div>

<!-- Date Filter -->
<div class="date-filter">
    <form method="get" class="d-flex flex-wrap align-items-end gap-3">
        <div>
            <label class="form-label small fw-semibold mb-1">Từ ngày</label>
            <input type="date" name="fromDate" class="form-control" value="@fromDate.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label class="form-label small fw-semibold mb-1">Đến ngày</label>
            <input type="date" name="toDate" class="form-control" value="@toDate.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <button type="submit" class="btn btn-brand px-4" style="height:38px">
                <i class="bi bi-funnel me-1"></i>Lọc
            </button>
        </div>
        <div class="d-flex gap-2 ms-auto">
            <a href="@Url.Action("Index", "Report", new { area = "Admin", fromDate = DateTime.Now.Date.AddDays(-6).ToString("yyyy-MM-dd"), toDate = DateTime.Now.Date.ToString("yyyy-MM-dd") })" class="btn-quick">7 ngày</a>
            <a href="@Url.Action("Index", "Report", new { area = "Admin", fromDate = DateTime.Now.Date.AddDays(-29).ToString("yyyy-MM-dd"), toDate = DateTime.Now.Date.ToString("yyyy-MM-dd") })" class="btn-quick">30 ngày</a>
            <a href="@Url.Action("Index", "Report", new { area = "Admin", fromDate = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).ToString("yyyy-MM-dd"), toDate = DateTime.Now.Date.ToString("yyyy-MM-dd") })" class="btn-quick">Tháng này</a>
            <a href="@Url.Action("Index", "Report", new { area = "Admin", fromDate = new DateTime(DateTime.Now.Year, 1, 1).ToString("yyyy-MM-dd"), toDate = DateTime.Now.Date.ToString("yyyy-MM-dd") })" class="btn-quick">Năm nay</a>
        </div>
    </form>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-graph-up me-2"></i>Tổng quan
        <small class="text-muted fs-6 fw-normal">(@fromDate.ToString("dd/MM/yyyy") - @toDate.ToString("dd/MM/yyyy"))</small>
    </h4>
    <button class="btn btn-outline-secondary" onclick="window.print()">
        <i class="bi bi-printer me-1"></i>In báo cáo
    </button>
</div>

<!-- Stats Overview -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="report-stat">
            <div class="icon blue"><i class="bi bi-bag-check"></i></div>
            <div class="label">Tổng đơn hàng</div>
            <div class="value">@totalOrders.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="report-stat">
            <div class="icon orange"><i class="bi bi-currency-dollar"></i></div>
            <div class="label">Doanh thu</div>
            <div class="value">@totalRevenue.ToString("N0")₫</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="report-stat">
            <div class="icon green"><i class="bi bi-check-circle"></i></div>
            <div class="label">Hoàn thành</div>
            <div class="value">@completedOrders.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="report-stat">
            <div class="icon red"><i class="bi bi-x-circle"></i></div>
            <div class="label">Đã hủy</div>
            <div class="value">@cancelledOrders.ToString("N0")</div>
        </div>
    </div>
</div>

<!-- Order Status -->
<div class="chart-card mb-4">
    <h6><i class="bi bi-pie-chart me-2"></i>Trạng thái đơn hàng trong khoảng</h6>
    <div class="order-status-grid">
        <div class="status-card pending">
            <div class="count">@pendingOrders</div>
            <div class="label">Chờ xác nhận</div>
        </div>
        <div class="status-card confirmed">
            <div class="count">@confirmedOrders</div>
            <div class="label">Đã xác nhận</div>
        </div>
        <div class="status-card shipping">
            <div class="count">@shippingOrders</div>
            <div class="label">Đang giao</div>
        </div>
        <div class="status-card completed">
            <div class="count">@completedOrders</div>
            <div class="label">Hoàn thành</div>
        </div>
        <div class="status-card cancelled">
            <div class="count">@cancelledOrders</div>
            <div class="label">Đã hủy</div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="chart-card">
            <h6><i class="bi bi-graph-up-arrow me-2"></i>Doanh thu trong khoảng</h6>
            <div style="height: 300px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="chart-card">
            <h6><i class="bi bi-bar-chart me-2"></i>Số đơn hàng</h6>
            <div style="height: 300px;">
                <canvas id="ordersChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Top Products -->
<div class="chart-card">
    <h6><i class="bi bi-trophy me-2"></i>Top 10 sản phẩm bán chạy trong khoảng</h6>
    @if (topProducts.Any())
    {
        @foreach (var p in topProducts)
        {
            <div class="product-item">
                @if (!string.IsNullOrEmpty(p.ThumbnailUrl))
                {
                    <img src="@p.ThumbnailUrl" alt="@p.Name">
                }
                else
                {
                    <div style="width:60px;height:60px;border-radius:8px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;border:1px solid #e5e7eb">
                        <i class="bi bi-image text-muted"></i>
                    </div>
                }
                <div class="info">
                    <div class="name">@p.Name</div>
                    <div class="stats">
                        Đã bán: <strong>@p.TotalQuantity</strong> sản phẩm •
                        Doanh thu: <strong class="text-success">@((decimal)p.TotalRevenue).ToString("N0")₫</strong>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center text-muted py-4">Chưa có dữ liệu trong khoảng thời gian này</div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const revenueCtx = document.getElementById('revenueChart').getContext('2d');
    new Chart(revenueCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartLabels)),
            datasets: [{
                label: 'Doanh thu (₫)',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartValues)),
                borderColor: '#667eea',
                backgroundColor: 'rgba(102, 126, 234, 0.1)',
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { callback: function(value) { return value.toLocaleString() + '₫'; } }
                }
            }
        }
    });

    const ordersCtx = document.getElementById('ordersChart').getContext('2d');
    new Chart(ordersCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartLabels)),
            datasets: [{
                label: 'Đơn hàng',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartOrders)),
                backgroundColor: '#10b981',
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
</script>
}
