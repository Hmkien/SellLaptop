@using WebsiteSellLaptop.Models.Enums
@{
    ViewData["Title"] = "Trang chủ";
    var featuredProducts = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var banners = ViewBag.Banners as List<Banner> ?? new List<Banner>();
}

@section Styles {
<style>
    .hero{background:linear-gradient(135deg,#ffffff 0%,#eef2ff 100%);border-radius:28px;padding:52px;border:1px solid #e5e7eb;box-shadow:0 20px 60px rgba(15,23,42,0.08)}
    .hero-img{border-radius:18px;object-fit:cover;width:100%;height:100%;min-height:320px;box-shadow:0 18px 50px rgba(37,99,235,0.16)}
    .pill{display:inline-flex;align-items:center;gap:8px;padding:10px 16px;background:#e0ecff;color:#1d4ed8;border-radius:999px;font-weight:600;font-size:14px}
    .stat{background:#fff;border-radius:14px;padding:12px 16px;border:1px solid #e5e7eb}
    .category-card,.product-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;transition:transform 0.2s,box-shadow 0.2s}
    .category-card:hover,.product-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px rgba(15,23,42,0.08)}
    .category-card{padding:0;overflow:hidden}
    .category-card img{width:100%;height:140px;object-fit:cover}
    .category-card .category-body{padding:14px;text-align:center}
    .category-card .category-title{font-weight:700;margin-bottom:6px}
    .category-card .category-sub{color:var(--muted);font-size:13px}
    .product-card{display:flex;flex-direction:column;gap:8px;min-height:360px;padding:16px}
    .product-card h6{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin:0}
    .product-meta{margin-top:auto}
    .thumb{border-radius:12px;object-fit:cover;width:100%;height:170px}
    .price{font-weight:800;color:var(--brand);font-size:18px}
    .old-price{color:var(--muted);text-decoration:line-through;font-size:14px}
    .step-card{background:#fff;border-radius:14px;border:1px dashed #d1d5db;padding:18px;height:100%}
    .step-badge{min-width:44px;height:44px;border-radius:50%;background:var(--brand);color:#fff;display:inline-flex;align-items:center;justify-content:center;font-weight:700}
    .feature-icon{width:48px;height:48px;border-radius:12px;background:#eef2ff;display:inline-flex;align-items:center;justify-content:center;color:var(--brand);font-size:20px;margin-right:12px}
</style>
}

<div class="container my-5">
    <!-- Hero Section -->
    <section class="hero row g-4 align-items-center">
        <div class="col-lg-6">
            <div class="pill mb-3"><i class="bi bi-lightning-charge-fill"></i> Deal tuần - Giảm đến 15%</div>
            <h1 class="fw-bold display-5 mb-3">Laptop hiệu năng cao, giao tận tay trong 2 giờ</h1>
            <p class="text-muted mb-4">Hàng chính hãng, bảo hành tại hãng, hỗ trợ cài đặt và backup dữ liệu trước khi giao</p>
            <div class="d-flex gap-3 flex-wrap">
                <a class="btn btn-brand btn-lg" asp-controller="Product" asp-action="Index">Chọn laptop</a>
                <a class="btn btn-outline-dark btn-lg" href="#">Xem phụ kiện</a>
            </div>
            <div class="row row-cols-3 g-2 mt-4">
                <div class="col"><div class="stat small"><i class="bi bi-truck"></i> Giao nhanh 2h</div></div>
                <div class="col"><div class="stat small"><i class="bi bi-shield-check"></i> Bảo hành 1-1</div></div>
                <div class="col"><div class="stat small"><i class="bi bi-arrow-repeat"></i> Đổi trả 7 ngày</div></div>
            </div>
        </div>
        <div class="col-lg-6">
            <img src="https://images.unsplash.com/photo-1481277542470-605612bd2d61?auto=format&fit=crop&w=1400&q=80" class="hero-img" alt="Laptop">
        </div>
    </section>

    <!-- Categories -->
    @if (categories.Any())
    {
        <section class="section">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title">Danh mục nổi bật</h2>
            </div>
            <div class="row g-3">
                @foreach (var cat in categories)
                {
                    <div class="col-6 col-md-3">
                        <div class="category-card h-100">
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@cat.ImageUrl" alt="@cat.Name">
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1518779578993-ec3579fee39f?auto=format&fit=crop&w=800&q=80" alt="@cat.Name">
                            }
                            <div class="category-body">
                                <div class="category-title">@cat.Name</div>
                                <div class="category-sub">@(cat.Description ?? "Khám phá ngay")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Featured Products -->
    @if (featuredProducts.Any())
    {
        <section class="section">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title">Laptop nổi bật</h2>
                <a asp-controller="Product" asp-action="Index" class="text-primary">Xem tất cả</a>
            </div>
            <div class="row g-4">
                @foreach (var product in featuredProducts.Take(4))
                {
                    <div class="col-md-3">
                        <div class="product-card h-100">
                            @if (!string.IsNullOrEmpty(product.ThumbnailUrl))
                            {
                                <img src="@product.ThumbnailUrl" class="thumb" alt="@product.Name">
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&w=900&q=80" class="thumb" alt="@product.Name">
                            }
                            <div class="d-flex justify-content-between align-items-start mt-2 mb-1">
                                <h6 class="fw-semibold">@product.Name</h6>
                                @if (product.IsFeatured)
                                {
                                    <span class="badge bg-success">Nổi bật</span>
                                }
                            </div>
                            <p class="text-muted small mb-1">@product.CPU</p>
                            <div class="product-meta">
                                <div class="price">@product.Price.ToString("N0")₫</div>
                                @if (product.DiscountPrice.HasValue && product.DiscountPrice > 0)
                                {
                                    <div class="old-price">@product.DiscountPrice.Value.ToString("N0")₫</div>
                                }
                                <button class="btn btn-dark w-100 mt-3">Thêm vào giỏ</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    else
    {
        <section class="section">
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Chưa có sản phẩm nào. Vui lòng thêm sản phẩm trong <a asp-area="Admin" asp-controller="Product" asp-action="Create">Admin Panel</a>.
            </div>
        </section>
    }

    <!-- Process Steps -->
    <section class="section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title">Quy trình mua nhanh</h2>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="step-card">
                    <div class="d-flex align-items-start gap-3">
                        <div class="step-badge">1</div>
                        <div>
                            <div class="fw-semibold">Chọn nhu cầu</div>
                            <p class="text-muted small mb-0">Gaming, đồ họa, văn phòng</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="step-card">
                    <div class="d-flex align-items-start gap-3">
                        <div class="step-badge">2</div>
                        <div>
                            <div class="fw-semibold">So sánh nhanh</div>
                            <p class="text-muted small mb-0">Hiệu năng, màn hình, giá</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="step-card">
                    <div class="d-flex align-items-start gap-3">
                        <div class="step-badge">3</div>
                        <div>
                            <div class="fw-semibold">Đặt cọc online</div>
                            <p class="text-muted small mb-0">Giữ máy 24h</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="step-card">
                    <div class="d-flex align-items-start gap-3">
                        <div class="step-badge">4</div>
                        <div>
                            <div class="fw-semibold">Giao nhanh</div>
                            <p class="text-muted small mb-0">Giao 2h, cài đặt sẵn</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title">Ưu đãi & Dịch vụ</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="d-flex align-items-start p-3 bg-white rounded-3 border h-100">
                    <div class="feature-icon"><i class="bi bi-credit-card-2-front-fill"></i></div>
                    <div>
                        <h6 class="fw-semibold">Trả góp 0%</h6>
                        <p class="text-muted small mb-0">Hỗ trợ nhiều ngân hàng, duyệt online 5 phút</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex align-items-start p-3 bg-white rounded-3 border h-100">
                    <div class="feature-icon"><i class="bi bi-building"></i></div>
                    <div>
                        <h6 class="fw-semibold">Hỗ trợ doanh nghiệp</h6>
                        <p class="text-muted small mb-0">Hoá đơn VAT, hợp đồng, giao tận nơi</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex align-items-start p-3 bg-white rounded-3 border h-100">
                    <div class="feature-icon"><i class="bi bi-tools"></i></div>
                    <div>
                        <h6 class="fw-semibold">Kỹ thuật tại chỗ</h6>
                        <p class="text-muted small mb-0">Backup dữ liệu, tối ưu hiệu năng</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
