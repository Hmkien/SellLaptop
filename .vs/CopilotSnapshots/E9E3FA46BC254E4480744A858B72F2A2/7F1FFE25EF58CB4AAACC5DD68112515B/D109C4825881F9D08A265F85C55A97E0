<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LapTopHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        :root {--brand:#2563eb;--dark:#0f172a;--muted:#6b7280;--card:#ffffff;--bg:#f1f3f7}
        body{font-family:'Manrope',system-ui,-apple-system,sans-serif;color:var(--dark);background:var(--bg);line-height:1.6;margin:0;padding:0}
        a{text-decoration:none}
        .navbar{box-shadow:0 10px 30px rgba(15,23,42,0.06)}
        .section{margin-top:72px}
        .section-title{font-weight:700;letter-spacing:-0.01em}
        .nav-search{position:relative;width:260px}
        .nav-search input{border-radius:12px;padding-left:38px;border:1px solid #e5e7eb;background:#f8fafc;height:42px;width:100%}
        .nav-search input:focus{border-color:var(--brand);box-shadow:0 0 0 3px rgba(37,99,235,.12);outline:none}
        .nav-search .search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted)}
        .nav-icon{position:relative;width:42px;height:42px;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;color:var(--dark);font-size:18px;background:#f8fafc;border:1px solid #e5e7eb;transition:all .15s}
        .nav-icon:hover{background:#eef2ff;color:var(--brand);border-color:var(--brand)}
        .nav-icon .icon-badge{position:absolute;top:-4px;right:-4px;width:18px;height:18px;border-radius:50%;background:#ef4444;color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center}
        .btn-brand{background:var(--brand);color:#fff;border:none;border-radius:10px;font-weight:600}
        .btn-brand:hover{background:#1d4ed8;color:#fff}
        .footer{color:#e2e8f0;background:#0b1223;padding:40px 0}
        .footer a{color:#e2e8f0}
        .footer a:hover{color:var(--brand)}
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Top Bar -->
    <header class="py-3 bg-white border-bottom">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <div class="badge bg-dark text-white" style="border-radius:50rem;padding:4px 12px;font-size:12px">Mới</div>
                <span class="text-muted small">Surface Pro 11 - Hàng sẵn kho, giao 2h</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <a href="#stores" class="text-muted small"><i class="bi bi-geo-alt"></i> Hệ thống cửa hàng</a>
                <a href="tel:19006868" class="text-muted small"><i class="bi bi-telephone"></i> 1900 6868</a>
            </div>
        </div>
    </header>

    <!-- Main Navigation -->
    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">LapTopHub</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Laptop</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Phụ kiện</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Đối tác</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Blog</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <div class="nav-search d-none d-lg-block">
                        <i class="bi bi-search search-icon"></i>
                        <input type="search" class="form-control" placeholder="Tìm laptop, phụ kiện...">
                    </div>
                    <a href="#" class="nav-icon" title="Giỏ hàng">
                        <i class="bi bi-bag"></i>
                        <span class="icon-badge">0</span>
                    </a>
                    <div class="dropdown">
                        <a href="#" class="nav-icon" data-bs-toggle="dropdown" title="Tài khoản">
                            <i class="bi bi-person"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person-circle me-2"></i>Tài khoản</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-receipt me-2"></i>Đơn hàng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-2"></i>Đăng ký</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3">
                    <h5 class="fw-bold mb-3">LapTopHub</h5>
                    <p class="small">Chuyên cung cấp laptop, phụ kiện chính hãng với giá tốt nhất thị trường.</p>
                    <div class="d-flex gap-2">
                        <a href="#" class="nav-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="nav-icon"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="nav-icon"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-bold mb-3">Sản phẩm</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Laptop Gaming</a></li>
                        <li class="mb-2"><a href="#">Laptop Văn phòng</a></li>
                        <li class="mb-2"><a href="#">Laptop Đồ họa</a></li>
                        <li class="mb-2"><a href="#">Phụ kiện</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-bold mb-3">Hỗ trợ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Chính sách bảo hành</a></li>
                        <li class="mb-2"><a href="#">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a href="#">Hướng dẫn mua hàng</a></li>
                        <li class="mb-2"><a href="#">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-bold mb-3">Liên hệ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><i class="bi bi-telephone me-2"></i>1900 6868</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>support@laptophub.vn</li>
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>Hà Nội, Việt Nam</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4" style="border-color:rgba(255,255,255,0.1)">
            <div class="text-center small">
                <p class="mb-0">&copy; 2026 LapTopHub. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
