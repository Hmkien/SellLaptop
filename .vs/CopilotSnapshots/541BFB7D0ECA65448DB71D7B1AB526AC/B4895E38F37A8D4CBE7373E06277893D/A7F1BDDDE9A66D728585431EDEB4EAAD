        public async Task<IActionResult> ExportOverview(DateTime? fromDate, DateTime? toDate)
        {
            var to = toDate?.Date.AddDays(1) ?? DateTime.Now.Date.AddDays(1);
            var from = fromDate?.Date ?? to.AddDays(-30);

            var totalOrders = await _context.Orders.Where(o => o.Created >= from && o.Created < to).CountAsync();
            var completedOrders = await _context.Orders.Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Completed).CountAsync();
            var cancelledOrders = await _context.Orders.Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Cancelled).CountAsync();
            var pendingOrders = await _context.Orders.Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Pending).CountAsync();
            var confirmedOrders = await _context.Orders.Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Confirmed).CountAsync();
            var shippingOrders = await _context.Orders.Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Shipping).CountAsync();
            var totalRevenue = await _context.Orders.Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Completed).SumAsync(o => o.TotalAmount);

            var topProducts = await _context.OrderDetails
                .Include(od => od.Order)
                .Include(od => od.Product)
                .Where(od => od.Order != null && od.Order.Created >= from && od.Order.Created < to
                    && od.Order.OrderStatus == OrderStatus.Completed && od.Product != null)
                .GroupBy(od => new { od.ProductId, od.Product!.Name })
                .Select(g => new { g.Key.Name, TotalQuantity = g.Sum(od => od.Quantity), TotalRevenue = g.Sum(od => od.TotalPrice) })
                .OrderByDescending(x => x.TotalQuantity)
                .Take(10)
                .ToListAsync();

            using var package = new ExcelPackage();
            var ws = package.Workbook.Worksheets.Add("Tổng quan");

            // ── Title ──
            ExcelSetTitle(ws, "BÁO CÁO TỔNG QUAN", 1, 4);
            ws.Cells[2, 1].Value = $"Kỳ báo cáo: {from:dd/MM/yyyy} — {to.AddDays(-1):dd/MM/yyyy}";
            ws.Cells[2, 1, 2, 4].Merge = true;
            ws.Cells[2, 1].Style.Font.Italic = true;
            ws.Cells[2, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;
            ws.Cells[3, 1].Value = $"Xuất lúc: {DateTime.Now:dd/MM/yyyy HH:mm}";
            ws.Cells[3, 1, 3, 4].Merge = true;
            ws.Cells[3, 1].Style.Font.Italic = true;
            ws.Cells[3, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;

            // ── Stats ──
            int r = 5;
            ExcelSetSectionHeader(ws, "THỐNG KÊ CHUNG", r, 4);
            r++;
            string[,] stats = {
                { "Tổng đơn hàng", totalOrders.ToString("N0"), "Đơn hoàn thành", completedOrders.ToString("N0") },
                { "Tổng doanh thu", $"{totalRevenue:N0} ₫", "Đơn đã hủy", cancelledOrders.ToString("N0") },
                { "Chờ xác nhận", pendingOrders.ToString("N0"), "Đã xác nhận", confirmedOrders.ToString("N0") },
                { "Đang giao", shippingOrders.ToString("N0"), "", "" }
            };
            for (int i = 0; i < stats.GetLength(0); i++, r++)
            {
                ExcelSetStatRow(ws, r, stats[i, 0], stats[i, 1], stats[i, 2], stats[i, 3]);
            }

            // ── Top Products ──
            r += 1;
            ExcelSetSectionHeader(ws, "TOP 10 SẢN PHẨM BÁN CHẠY", r, 4);
            r++;
            ExcelSetHeaderRow(ws, r, ["STT", "Tên sản phẩm", "Số lượng đã bán", "Doanh thu (₫)"]);
            r++;
            for (int i = 0; i < topProducts.Count; i++, r++)
            {
                ws.Cells[r, 1].Value = i + 1;
                ws.Cells[r, 2].Value = topProducts[i].Name;
                ws.Cells[r, 3].Value = topProducts[i].TotalQuantity;
                ws.Cells[r, 4].Value = (double)topProducts[i].TotalRevenue;
                ws.Cells[r, 4].Style.Numberformat.Format = "#,##0";
                if (i % 2 == 1) ExcelSetStripedRow(ws, r, 4);
            }

            ws.Cells[ws.Dimension.Address].AutoFitColumns(12, 60);
            ws.Column(2).Width = 40;

            var stream = new MemoryStream();
            package.SaveAs(stream);
            stream.Position = 0;
            return File(stream, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                $"BaoCaoTongQuan_{from:yyyyMMdd}_{to.AddDays(-1):yyyyMMdd}.xlsx");
        }

        public async Task<IActionResult> ExportRevenue(DateTime? fromDate, DateTime? toDate, string groupBy = "day")
        {
            var to = toDate?.Date.AddDays(1) ?? DateTime.Now.Date.AddDays(1);
            var from = fromDate?.Date ?? to.AddDays(-30);

            var orders = await _context.Orders
                .Where(o => o.Created >= from && o.Created < to && o.OrderStatus == OrderStatus.Completed)
                .OrderBy(o => o.Created)
                .ToListAsync();

            using var package = new ExcelPackage();

            // ── Sheet 1: Tóm tắt ──
            var ws1 = package.Workbook.Worksheets.Add("Tóm tắt");
            ExcelSetTitle(ws1, "BÁO CÁO DOANH THU", 1, 4);
            ws1.Cells[2, 1].Value = $"Kỳ báo cáo: {from:dd/MM/yyyy} — {to.AddDays(-1):dd/MM/yyyy} | Nhóm theo: {(groupBy == "month" ? "Tháng" : groupBy == "week" ? "Tuần" : "Ngày")}";
            ws1.Cells[2, 1, 2, 4].Merge = true;
            ws1.Cells[2, 1].Style.Font.Italic = true;
            ws1.Cells[2, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;

            int r = 4;
            ExcelSetSectionHeader(ws1, "THỐNG KÊ DOANH THU", r, 4);
            r++;
            decimal totalRevenue = orders.Sum(o => o.TotalAmount);
            decimal avgOrder = orders.Count > 0 ? orders.Average(o => o.TotalAmount) : 0m;
            decimal maxOrder = orders.Count > 0 ? orders.Max(o => o.TotalAmount) : 0m;
            string[,] revStats = {
                { "Tổng doanh thu", $"{totalRevenue:N0} ₫", "Số đơn hoàn thành", orders.Count.ToString("N0") },
                { "Giá trị TB/đơn", $"{avgOrder:N0} ₫", "Đơn cao nhất", $"{maxOrder:N0} ₫" }
            };
            for (int i = 0; i < revStats.GetLength(0); i++, r++)
            {
                ExcelSetStatRow(ws1, r, revStats[i, 0], revStats[i, 1], revStats[i, 2], revStats[i, 3]);
            }

            // Payment breakdown
            r += 1;
            ExcelSetSectionHeader(ws1, "DOANH THU THEO PHƯƠNG THỨC THANH TOÁN", r, 4);
            r++;
            ExcelSetHeaderRow(ws1, r, ["Phương thức", "Số đơn", "Doanh thu (₫)", "Tỷ lệ (%)"]);
            r++;
            var byPayment = orders.GroupBy(o => o.PaymentMethod)
                .Select(g => new { Method = g.Key, Total = g.Sum(o => o.TotalAmount), Count = g.Count() })
                .OrderByDescending(x => x.Total).ToList();
            for (int i = 0; i < byPayment.Count; i++, r++)
            {
                string label = byPayment[i].Method switch
                {
                    PaymentMethod.COD => "Thanh toán khi nhận hàng",
                    PaymentMethod.BankTransfer => "Chuyển khoản ngân hàng",
                    PaymentMethod.CreditCard => "Thẻ tín dụng",
                    PaymentMethod.EWallet => "Ví điện tử",
                    _ => byPayment[i].Method.ToString()
                };
                ws1.Cells[r, 1].Value = label;
                ws1.Cells[r, 2].Value = byPayment[i].Count;
                ws1.Cells[r, 3].Value = (double)byPayment[i].Total;
                ws1.Cells[r, 3].Style.Numberformat.Format = "#,##0";
                double pct = totalRevenue > 0 ? (double)(byPayment[i].Total / totalRevenue * 100) : 0;
                ws1.Cells[r, 4].Value = Math.Round(pct, 1);
                ws1.Cells[r, 4].Style.Numberformat.Format = "0.0\"%\"";
                if (i % 2 == 1) ExcelSetStripedRow(ws1, r, 4);
            }

            // Revenue over time
            r += 1;
            ExcelSetSectionHeader(ws1, "DOANH THU THEO THỜI GIAN", r, 3);
            r++;
            ExcelSetHeaderRow(ws1, r, ["Kỳ", "Số đơn", "Doanh thu (₫)"]);
            r++;
            IEnumerable<(string Label, int Count, decimal Revenue)> timeData = groupBy switch
            {
                "month" => orders.GroupBy(o => new { o.Created.Year, o.Created.Month })
                    .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month)
                    .Select(g => ($"{g.Key.Month:D2}/{g.Key.Year}", g.Count(), g.Sum(o => o.TotalAmount))),
                "week" => GetWeeklyData(orders, from, to),
                _ => orders.GroupBy(o => o.Created.Date)
                    .OrderBy(g => g.Key)
                    .Select(g => (g.Key.ToString("dd/MM/yyyy"), g.Count(), g.Sum(o => o.TotalAmount)))
            };
            int ti = 0;
            foreach (var (label, count, rev) in timeData)
            {
                ws1.Cells[r, 1].Value = label;
                ws1.Cells[r, 2].Value = count;
                ws1.Cells[r, 3].Value = (double)rev;
                ws1.Cells[r, 3].Style.Numberformat.Format = "#,##0";
                if (ti % 2 == 1) ExcelSetStripedRow(ws1, r, 3);
                r++; ti++;
            }

            ws1.Cells[ws1.Dimension.Address].AutoFitColumns(14, 50);

            // ── Sheet 2: Chi tiết đơn hàng ──
            var ws2 = package.Workbook.Worksheets.Add("Chi tiết đơn hàng");
            ExcelSetTitle(ws2, "CHI TIẾT ĐƠN HÀNG HOÀN THÀNH", 1, 7);
            ws2.Cells[2, 1].Value = $"Kỳ báo cáo: {from:dd/MM/yyyy} — {to.AddDays(-1):dd/MM/yyyy}";
            ws2.Cells[2, 1, 2, 7].Merge = true;
            ws2.Cells[2, 1].Style.Font.Italic = true;
            ws2.Cells[2, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;

            r = 4;
            ExcelSetHeaderRow(ws2, r, ["Mã đơn", "Khách hàng", "Email", "Ngày đặt", "Phương thức TT", "Giảm giá (₫)", "Tổng tiền (₫)"]);
            r++;
            var detailOrders = orders.OrderByDescending(o => o.Created).ToList();
            for (int i = 0; i < detailOrders.Count; i++, r++)
            {
                string pm = detailOrders[i].PaymentMethod switch
                {
                    PaymentMethod.COD => "COD",
                    PaymentMethod.BankTransfer => "Chuyển khoản",
                    PaymentMethod.CreditCard => "Thẻ tín dụng",
                    PaymentMethod.EWallet => "Ví điện tử",
                    _ => detailOrders[i].PaymentMethod.ToString()
                };
                ws2.Cells[r, 1].Value = detailOrders[i].OrderCode;
                ws2.Cells[r, 2].Value = detailOrders[i].FullName;
                ws2.Cells[r, 3].Value = detailOrders[i].Email;
                ws2.Cells[r, 4].Value = detailOrders[i].Created.ToString("dd/MM/yyyy HH:mm");
                ws2.Cells[r, 5].Value = pm;
                ws2.Cells[r, 6].Value = (double)(detailOrders[i].DiscountAmount ?? 0);
                ws2.Cells[r, 6].Style.Numberformat.Format = "#,##0";
                ws2.Cells[r, 7].Value = (double)detailOrders[i].TotalAmount;
                ws2.Cells[r, 7].Style.Numberformat.Format = "#,##0";
                if (i % 2 == 1) ExcelSetStripedRow(ws2, r, 7);
            }
            // Total row
            ws2.Cells[r, 6].Value = "TỔNG";
            ws2.Cells[r, 6].Style.Font.Bold = true;
            ws2.Cells[r, 7].Value = (double)totalRevenue;
            ws2.Cells[r, 7].Style.Numberformat.Format = "#,##0";
            ws2.Cells[r, 7].Style.Font.Bold = true;
            ws2.Cells[r, 7].Style.Fill.PatternType = ExcelFillStyle.Solid;
            ws2.Cells[r, 7].Style.Fill.BackgroundColor.SetColor(Color.FromArgb(220, 252, 231));

            ws2.Cells[ws2.Dimension.Address].AutoFitColumns(12, 50);

            var stream = new MemoryStream();
            package.SaveAs(stream);
            stream.Position = 0;
            return File(stream, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                $"BaoCaoDoanhThu_{from:yyyyMMdd}_{to.AddDays(-1):yyyyMMdd}.xlsx");
        }

