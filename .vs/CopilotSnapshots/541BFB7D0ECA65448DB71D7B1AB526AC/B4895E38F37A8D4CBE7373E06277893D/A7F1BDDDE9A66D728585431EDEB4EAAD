            r++;
            string[,] invStats = {
                { "Tổng sản phẩm", products.Count.ToString("N0"), "Tổng tồn kho", products.Sum(p => p.StockQuantity).ToString("N0") + " sản phẩm" },
                { "Tổng giá trị tồn kho", $"{products.Sum(p => p.Price * p.StockQuantity):N0} ₫", "Hết hàng", products.Count(p => p.StockQuantity == 0).ToString("N0") + " sản phẩm" },
                { "Sắp hết hàng (≤5)", products.Count(p => p.StockQuantity > 0 && p.StockQuantity <= 5).ToString("N0") + " sản phẩm", "", "" }
            };
            for (int i = 0; i < invStats.GetLength(0); i++, r++)
            {
                ExcelSetStatRow(ws1, r, invStats[i, 0], invStats[i, 1], invStats[i, 2], invStats[i, 3]);
            }

            // By category
            r += 1;
            ExcelSetSectionHeader(ws1, "TỒN KHO THEO DANH MỤC", r, 4);
            r++;
            ExcelSetHeaderRow(ws1, r, ["Danh mục", "Số sản phẩm", "Tổng tồn kho", "Giá trị tồn kho (₫)"]);
            r++;
            var byCategory = products.GroupBy(p => p.Category?.Name ?? "Không phân loại")
                .Select(g => new { Name = g.Key, Count = g.Count(), Stock = g.Sum(p => p.StockQuantity), Value = g.Sum(p => p.Price * p.StockQuantity) })
                .OrderByDescending(x => x.Stock).ToList();
            for (int i = 0; i < byCategory.Count; i++, r++)
            {
                ws1.Cells[r, 1].Value = byCategory[i].Name;
                ws1.Cells[r, 2].Value = byCategory[i].Count;
                ws1.Cells[r, 3].Value = byCategory[i].Stock;
                ws1.Cells[r, 4].Value = (double)byCategory[i].Value;
                ws1.Cells[r, 4].Style.Numberformat.Format = "#,##0";
                if (i % 2 == 1) ExcelSetStripedRow(ws1, r, 4);
            }

            // By brand
            r += 1;
            ExcelSetSectionHeader(ws1, "TỒN KHO THEO THƯƠNG HIỆU", r, 4);
            r++;
            ExcelSetHeaderRow(ws1, r, ["Thương hiệu", "Số sản phẩm", "Tổng tồn kho", "Giá trị tồn kho (₫)"]);
            r++;
            var byBrand = products.GroupBy(p => p.Brand?.Name ?? "Không phân loại")
                .Select(g => new { Name = g.Key, Count = g.Count(), Stock = g.Sum(p => p.StockQuantity), Value = g.Sum(p => p.Price * p.StockQuantity) })
                .OrderByDescending(x => x.Stock).ToList();
            for (int i = 0; i < byBrand.Count; i++, r++)
            {
                ws1.Cells[r, 1].Value = byBrand[i].Name;
                ws1.Cells[r, 2].Value = byBrand[i].Count;
                ws1.Cells[r, 3].Value = byBrand[i].Stock;
                ws1.Cells[r, 4].Value = (double)byBrand[i].Value;
                ws1.Cells[r, 4].Style.Numberformat.Format = "#,##0";
                if (i % 2 == 1) ExcelSetStripedRow(ws1, r, 4);
            }

            ws1.Cells[ws1.Dimension.Address].AutoFitColumns(14, 50);

            // ── Sheet 2: Chi tiết tồn kho ──
            var ws2 = package.Workbook.Worksheets.Add("Chi tiết tồn kho");
            ExcelSetTitle(ws2, "CHI TIẾT TỒN KHO", 1, 8);
            ws2.Cells[2, 1].Value = $"Xuất lúc: {DateTime.Now:dd/MM/yyyy HH:mm}";
            ws2.Cells[2, 1, 2, 8].Merge = true;
            ws2.Cells[2, 1].Style.Font.Italic = true;
            ws2.Cells[2, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;

            r = 4;
            ExcelSetHeaderRow(ws2, r, ["STT", "Tên sản phẩm", "Danh mục", "Thương hiệu", "Giá bán (₫)", "Tồn kho", "Giá trị tồn (₫)", "Trạng thái"]);
            r++;
            for (int i = 0; i < products.Count; i++, r++)
            {
                string status = products[i].StockQuantity == 0 ? "Hết hàng" : products[i].StockQuantity <= 5 ? "Sắp hết" : "Còn hàng";
                ws2.Cells[r, 1].Value = i + 1;
                ws2.Cells[r, 2].Value = products[i].Name;
                ws2.Cells[r, 3].Value = products[i].Category?.Name ?? "—";
                ws2.Cells[r, 4].Value = products[i].Brand?.Name ?? "—";
                ws2.Cells[r, 5].Value = (double)products[i].Price;
                ws2.Cells[r, 5].Style.Numberformat.Format = "#,##0";
                ws2.Cells[r, 6].Value = products[i].StockQuantity;
                ws2.Cells[r, 7].Value = (double)(products[i].Price * products[i].StockQuantity);
                ws2.Cells[r, 7].Style.Numberformat.Format = "#,##0";
                ws2.Cells[r, 8].Value = status;
                // Color status cell
                Color statusColor = products[i].StockQuantity == 0
                    ? Color.FromArgb(254, 226, 226)
                    : products[i].StockQuantity <= 5
                        ? Color.FromArgb(254, 243, 199)
                        : Color.FromArgb(220, 252, 231);
                ws2.Cells[r, 8].Style.Fill.PatternType = ExcelFillStyle.Solid;
                ws2.Cells[r, 8].Style.Fill.BackgroundColor.SetColor(statusColor);
                if (i % 2 == 1) ExcelSetStripedRow(ws2, r, 7);
            }

            ws2.Cells[ws2.Dimension.Address].AutoFitColumns(10, 50);
            ws2.Column(2).Width = 40;

            var stream = new MemoryStream();
            package.SaveAs(stream);
            stream.Position = 0;
            return File(stream, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                $"BaoCaoTonKho_{DateTime.Now:yyyyMMdd_HHmm}.xlsx");
        }

        // ── Excel helper methods ──

        private static void ExcelSetTitle(ExcelWorksheet ws, string title, int row, int colSpan)
        {
            ws.Cells[row, 1, row, colSpan].Merge = true;
            ws.Cells[row, 1].Value = title;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 1].Style.Font.Size = 16;
            ws.Cells[row, 1].Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;
            ws.Cells[row, 1].Style.Fill.PatternType = ExcelFillStyle.Solid;
            ws.Cells[row, 1].Style.Fill.BackgroundColor.SetColor(Color.FromArgb(14, 165, 233));
            ws.Cells[row, 1].Style.Font.Color.SetColor(Color.White);
            ws.Row(row).Height = 28;
        }

        private static void ExcelSetSectionHeader(ExcelWorksheet ws, string title, int row, int colSpan)
        {
            ws.Cells[row, 1, row, colSpan].Merge = true;
            ws.Cells[row, 1].Value = title;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 1].Style.Font.Size = 11;
            ws.Cells[row, 1].Style.Fill.PatternType = ExcelFillStyle.Solid;
            ws.Cells[row, 1].Style.Fill.BackgroundColor.SetColor(Color.FromArgb(30, 41, 59));
            ws.Cells[row, 1].Style.Font.Color.SetColor(Color.White);
            ws.Row(row).Height = 22;
        }

        private static void ExcelSetHeaderRow(ExcelWorksheet ws, int row, string[] headers)
        {
            for (int c = 0; c < headers.Length; c++)
            {
                ws.Cells[row, c + 1].Value = headers[c];
                ws.Cells[row, c + 1].Style.Font.Bold = true;
                ws.Cells[row, c + 1].Style.Fill.PatternType = ExcelFillStyle.Solid;
                ws.Cells[row, c + 1].Style.Fill.BackgroundColor.SetColor(Color.FromArgb(241, 245, 249));
                ws.Cells[row, c + 1].Style.Border.Bottom.Style = ExcelBorderStyle.Medium;
                ws.Cells[row, c + 1].Style.Border.Bottom.Color.SetColor(Color.FromArgb(14, 165, 233));
            }
            ws.Row(row).Height = 20;
        }

        private static void ExcelSetStatRow(ExcelWorksheet ws, int row, string lbl1, string val1, string lbl2, string val2)
        {
            ws.Cells[row, 1].Value = lbl1;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 2].Value = val1;
            if (!string.IsNullOrEmpty(lbl2))
            {
                ws.Cells[row, 3].Value = lbl2;
                ws.Cells[row, 3].Style.Font.Bold = true;
                ws.Cells[row, 4].Value = val2;
            }
            ws.Row(row).Height = 18;
        }

        private static void ExcelSetStripedRow(ExcelWorksheet ws, int row, int colCount)
        {
            ws.Cells[row, 1, row, colCount].Style.Fill.PatternType = ExcelFillStyle.Solid;
            ws.Cells[row, 1, row, colCount].Style.Fill.BackgroundColor.SetColor(Color.FromArgb(248, 250, 252));
        }

        private static IEnumerable<(string Label, int Count, decimal Revenue)> GetWeeklyData(
            List<WebsiteSellLaptop.Models.Entities.Order> orders, DateTime from, DateTime to)
        {
            var result = new List<(string, int, decimal)>();
            var start = from;
            while (start < to)
            {
                var end = start.AddDays(7) < to ? start.AddDays(7) : to;
                var week = orders.Where(o => o.Created >= start && o.Created < end).ToList();
                result.Add(($"{start:dd/MM} - {end.AddDays(-1):dd/MM}", week.Count, week.Sum(o => o.TotalAmount)));
                start = end;
            }
            return result;
        }
    }
